# ─────────────────────────────────────────────────────────────
#  Copy this file to ".env" and fill in your keys.
#  ".env" is git-ignored and will NEVER be committed.
#  Do NOT paste these keys into chat — put them here only.
# ─────────────────────────────────────────────────────────────

# Your live domain (used for canonical URLs, sitemap, OG tags)
SITE_URL=https://example.com

# Google Cloud — Places API (New) key
# Console → your project → APIs & Services → Credentials
GOOGLE_MAPS_API_KEY=

# Anthropic API key (content drafting)
ANTHROPIC_API_KEY=

# Optional: Unsplash access key (free image fallback)
# https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# How many posts to generate per automated run
POSTS_PER_RUN=2

# Guardrail thresholds (auto-skip a place if it fails these)
MIN_RATING=4.0
MIN_REVIEWS=50
