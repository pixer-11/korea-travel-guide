---
import { getCollection } from 'astro:content';
import { createHash } from 'node:crypto';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import Flag from '../../components/Flag.astro';
import Emoji from '../../components/Emoji.astro';
import Newsletter from '../../components/Newsletter.astro';
import { pickRepHeroUrl } from '../../lib/repImage';
import { isEventPast, eventSortValue } from '../../lib/eventStatus';
import { slugifyRegion } from '../../lib/slug';
import countriesData from '../../../data/countries.json';

// Optimized WebP thumbnail for a hero URL (scripts/build-wall.mjs), for faint
// region-tile backgrounds.
const wallThumb = (url) => (url ? `/wall/${createHash('sha1').update(url).digest('hex').slice(0, 16)}.webp` : '');

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  // Only build country pages that have posts — a country with 0 guides shows as a
  // non-clickable "Coming soon" tile, so an empty page would just be thin content
  // diluting a new domain's crawl budget.
  return countriesData.countries
    .map((c) => ({ c, cPosts: posts.filter((p) => (p.data.country ?? 'South Korea') === c.name) }))
    .filter((x) => x.cPosts.length > 0)
    .map(({ c, cPosts }) => ({
      params: { country: c.slug },
      props: { country: c, posts: cPosts },
    }));
}

const { country, posts } = Astro.props;
const regionCounts = new Map();
for (const p of posts) regionCounts.set(p.data.region, (regionCounts.get(p.data.region) ?? 0) + 1);
// Only the capital / famous cities (first entries in the country config) lead and
// get a larger, emphasized tile — regardless of guide count. The rest follow A→Z.
const majorOrder = (country.regions ?? []).slice(0, 3);
const isMajor = (r) => majorOrder.includes(r);
const majors = majorOrder.filter((r) => regionCounts.has(r));
const others = [...regionCounts.keys()]
  .filter((r) => !majorOrder.includes(r))
  .sort((a, b) => a.localeCompare(b));
const regionsWithPosts = [...majors, ...others];
// Exclude events from "Latest guides" — they have their own "What's on" section
// above, so including them here listed each event twice (e.g. the Turkey hub).
const latest = posts
  .filter((p) => p.data.category !== 'event')
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
// Upcoming events in this country — soonest first — for a "What's on" block.
const upcomingEvents = posts
  .filter((p) => p.data.category === 'event' && !isEventPast(p.data))
  .sort((a, b) => eventSortValue(a.data) - eventSortValue(b.data))
  .slice(0, 6);
const essentialsSlugs = new Set(
  (await getCollection('essentials', ({ data }) => !data.draft)).map((e) => e.id)
);
const hasEssentials = essentialsSlugs.has(country.slug);
// Region tile photo — prefer a landmark/scenery shot over food (see pickRepHeroUrl).
const regionImage = (r) => wallThumb(pickRepHeroUrl(posts.filter((p) => p.data.region === r)));

const site = Astro.site?.toString().replace(/\/$/, '') ?? '';
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

// Peak-intent affiliate CTAs for the country hub. Key Klook to the capital/lead
// city (better "things to do" results than a whole country), hotels to the
// country. Same attribution (marker 754088) as the post pages.
// Link "what's on" to the dedicated per-country events hub when one exists (built
// only for countries with ≥2 events); otherwise fall back to the global /events.
const countryEventCount = posts.filter((p) => p.data.category === 'event').length;
const eventsHref = countryEventCount >= 2 ? `/events/${country.slug}` : '/events';
const leadCity = (country.regions ?? [])[0] ?? country.name;
const klookCountry = `https://affiliate.klook.com/redirect?aid=api%7C13694%7C-754088%7Cpid%7C754088&k_site=${encodeURIComponent(`https://www.klook.com/en-US/search/?query=${leadCity}`)}`;
const hotelCountry = `https://search.hotellook.com/?marker=754088&destination=${encodeURIComponent(country.name)}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'CollectionPage', name: `${country.name} Travel Guide`, description: country.blurb, url: pageUrl, isPartOf: { '@id': `${site}/#site` } },
    { '@type': 'BreadcrumbList', itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site + '/' },
      { '@type': 'ListItem', position: 2, name: 'Destinations', item: `${site}/destinations` },
      { '@type': 'ListItem', position: 3, name: country.name, item: pageUrl },
    ] },
    ...(posts.length ? [{ '@type': 'ItemList', itemListElement: latest.map((p, i) => ({ '@type': 'ListItem', position: i + 1, url: `${site}/posts/${p.id}`, name: p.data.title })) }] : []),
  ],
};
---

<BaseLayout
  title={`${country.name} Travel Guide`}
  description={country.blurb?.slice(0, 155) ?? `Travel guides for ${country.name}.`}
  jsonLd={jsonLd}
>
  <section class="page-hero">
    <div class="wrap">
      <p class="eyebrow"><Flag code={country.iso2} size="1.4em" class="flag-ico" /> Destination</p>
      <h1>{country.name}</h1>
      <p class="region-blurb">{country.blurb}</p>
      {posts.length > 0 && (
        <p class="hub-meta">{posts.length} in-depth guides · updated daily · facts checked against live Google&nbsp;data</p>
      )}
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      {posts.length === 0 ? (
        <div class="fact-box" style="text-align:center">
          <p>In-depth {country.name} guides are on the way — we're building them now. Check back soon.</p>
        </div>
      ) : (
        <>
          {regionsWithPosts.length > 0 && (
            <div class="region-group">
              <h2>Where to go</h2>
              <div class="region-grid">
                {regionsWithPosts.map((r) => (
                  <a class:list={['region-tile', { 'is-major': isMajor(r) }]} href={`/regions/${slugifyRegion(r)}/`} style={regionImage(r) ? `background-image:url(${regionImage(r)})` : ''}><span>{r}</span></a>
                ))}
              </div>
            </div>
          )}

          {upcomingEvents.length > 0 && (
            <div class="region-group">
              <h2>What's on in {country.name}</h2>
              <div class="grid">
                {upcomingEvents.map((post) => (
                  <PostCard
                    href={`/posts/${post.id}`}
                    title={post.data.title}
                    description={post.data.description}
                    region={post.data.region}
                    category={post.data.category}
                    image={post.data.heroImage?.url}
                    eventEndDate={post.data.eventEndDate}
                  />
                ))}
              </div>
              <p style="margin-top:1rem"><a href={eventsHref} class="rule-link">All {country.name} events →</a></p>
            </div>
          )}

          <div class="region-group">
            <h2>Latest {country.name} guides</h2>
            <div class="grid">
              {latest.slice(0, 12).map((post) => (
                <PostCard
                  href={`/posts/${post.id}`}
                  title={post.data.title}
                  description={post.data.description}
                  region={post.data.region}
                  category={post.data.category}
                  image={post.data.heroImage?.url}
                  eventEndDate={post.data.eventEndDate}
                />
              ))}
            </div>
          </div>

          {hasEssentials && (
            <div class="region-group">
              <h2>Before you go</h2>
              <a class="essential-card" href={`/essentials/${country.slug}`} style="max-width:560px">
                <span class="ico"><Emoji name="compass" /></span>
                <div><h3>{country.name} travel essentials</h3><p>Visa & entry, getting around, money, best time to visit, and emergency numbers — with official sources.</p></div>
              </a>
            </div>
          )}

          <div class="book-cta">
            <span class="book-cta-label">Planning a trip to {country.name}?</span>
            <div class="book-cta-btns">
              <a class="book-btn book-btn-primary" href={klookCountry} target="_blank" rel="sponsored noopener"><Emoji name="admission-tickets" /> Things to do</a>
              <a class="book-btn" href={hotelCountry} target="_blank" rel="sponsored noopener"><Emoji name="hotel" /> Find hotels</a>
              <a class="book-btn" href="/flights" rel="sponsored noopener"><Emoji name="airplane" /> Flights</a>
            </div>
          </div>
        </>
      )}
    </div>
  </section>

  <Newsletter
    heading={`Planning a trip to ${country.name}?`}
    dek={`New ${country.name} guides, upcoming events, and practical tips — straight to your inbox. No spam, unsubscribe anytime.`}
  />
</BaseLayout>
