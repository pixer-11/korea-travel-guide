---
import { getCollection } from 'astro:content';
import { createHash } from 'node:crypto';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import countriesData from '../../../data/countries.json';

// Optimized WebP thumbnail for a hero URL (scripts/build-wall.mjs), for faint
// region-tile backgrounds.
const wallThumb = (url) => (url ? `/wall/${createHash('sha1').update(url).digest('hex').slice(0, 16)}.webp` : '');

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return countriesData.countries.map((c) => ({
    params: { country: c.slug },
    props: { country: c, posts: posts.filter((p) => (p.data.country ?? 'South Korea') === c.name) },
  }));
}

const { country, posts } = Astro.props;
const regionCounts = new Map();
for (const p of posts) regionCounts.set(p.data.region, (regionCounts.get(p.data.region) ?? 0) + 1);
// Only the capital / famous cities (first entries in the country config) lead and
// get a larger, emphasized tile — regardless of guide count. The rest follow A→Z.
const majorOrder = (country.regions ?? []).slice(0, 3);
const isMajor = (r) => majorOrder.includes(r);
const majors = majorOrder.filter((r) => regionCounts.has(r));
const others = [...regionCounts.keys()]
  .filter((r) => !majorOrder.includes(r))
  .sort((a, b) => a.localeCompare(b));
const regionsWithPosts = [...majors, ...others];
const latest = posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const essentialsSlugs = new Set(
  (await getCollection('essentials', ({ data }) => !data.draft)).map((e) => e.id)
);
const hasEssentials = essentialsSlugs.has(country.slug);
const regionImage = (r) => {
  const p = posts.find((x) => x.data.region === r && x.data.heroImage?.url && !x.data.heroImage.url.includes('placeholder'));
  return wallThumb(p?.data.heroImage?.url);
};

const site = Astro.site?.toString().replace(/\/$/, '') ?? '';
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'CollectionPage', name: `${country.name} Travel Guide`, description: country.blurb, url: pageUrl, isPartOf: { '@id': `${site}/#site` } },
    { '@type': 'BreadcrumbList', itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site + '/' },
      { '@type': 'ListItem', position: 2, name: 'Destinations', item: `${site}/destinations` },
      { '@type': 'ListItem', position: 3, name: country.name, item: pageUrl },
    ] },
    ...(posts.length ? [{ '@type': 'ItemList', itemListElement: latest.map((p, i) => ({ '@type': 'ListItem', position: i + 1, url: `${site}/posts/${p.id}`, name: p.data.title })) }] : []),
  ],
};
---

<BaseLayout
  title={`${country.name} Travel Guide`}
  description={country.blurb?.slice(0, 155) ?? `Travel guides for ${country.name}.`}
  jsonLd={jsonLd}
>
  <section class="page-hero">
    <div class="wrap">
      <p class="eyebrow"><span style="font-size:1.4em;vertical-align:-2px">{country.flag}</span> Destination</p>
      <h1>{country.name}</h1>
      <p class="region-blurb">{country.blurb}</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      {posts.length === 0 ? (
        <div class="fact-box" style="text-align:center">
          <p>In-depth {country.name} guides are on the way — we're building them now. Check back soon.</p>
        </div>
      ) : (
        <>
          {regionsWithPosts.length > 0 && (
            <div class="region-group">
              <h2>Where to go</h2>
              <div class="region-grid">
                {regionsWithPosts.map((r) => (
                  <a class:list={['region-tile', { 'is-major': isMajor(r) }]} href={`/regions/${r.toLowerCase()}`} style={regionImage(r) ? `background-image:url(${regionImage(r)})` : ''}><span>{r}</span></a>
                ))}
              </div>
            </div>
          )}

          <div class="region-group">
            <h2>Latest {country.name} guides</h2>
            <div class="grid">
              {latest.slice(0, 12).map((post) => (
                <PostCard
                  href={`/posts/${post.id}`}
                  title={post.data.title}
                  description={post.data.description}
                  region={post.data.region}
                  category={post.data.category}
                  image={post.data.heroImage?.url}
                />
              ))}
            </div>
          </div>

          {hasEssentials && (
            <div class="region-group">
              <h2>Before you go</h2>
              <a class="essential-card" href={`/essentials/${country.slug}`} style="max-width:560px">
                <span class="ico">🧭</span>
                <div><h3>{country.name} travel essentials</h3><p>Visa & entry, getting around, money, best time to visit, and emergency numbers — with official sources.</p></div>
              </a>
            </div>
          )}
        </>
      )}
    </div>
  </section>
</BaseLayout>
