---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import { SITE } from '../../siteConfig';
import countriesData from '../../../data/countries.json';

const posts = await getCollection('posts', ({ data }) => !data.draft);
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const countFor = (name) => posts.filter((p) => (p.data.country ?? 'South Korea') === name).length;
// Representative photo per country — its newest real (non-placeholder) hero.
const repImage = (name) => {
  const p = posts.find(
    (p) => (p.data.country ?? 'South Korea') === name && p.data.heroImage?.url && !p.data.heroImage.url.includes('placeholder')
  );
  return p?.data.heroImage?.url ?? '';
};
const countries = countriesData.countries.map((c) => ({ ...c, count: countFor(c.name) }));

// Group by continent → scalable as more countries are added.
const CONTINENT_ORDER = ['Asia', 'Europe', 'North America', 'South America', 'Africa', 'Oceania', 'Other'];
const byContinent = {};
for (const c of countries) (byContinent[c.continent || 'Other'] ||= []).push(c);
const continents = CONTINENT_ORDER.filter((k) => byContinent[k]).map((k) => ({
  name: k,
  slug: k.toLowerCase().replace(/\s+/g, '-'),
  countries: byContinent[k].sort((a, b) => b.count - a.count || a.name.localeCompare(b.name)),
}));
const liveTotal = countries.filter((c) => c.count > 0).length;

const site = Astro.site?.toString().replace(/\/$/, '') ?? '';
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'CollectionPage', name: 'Destinations', description: 'Browse travel guides by continent and country.', url: pageUrl, isPartOf: { '@id': `${site}/#site` } },
    { '@type': 'BreadcrumbList', itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site + '/' },
      { '@type': 'ListItem', position: 2, name: 'Destinations', item: pageUrl },
    ] },
  ],
};
---

<BaseLayout
  title="Destinations — Travel Guides by Country"
  description={`Explore ${SITE.name}'s detailed, editor-reviewed travel guides by continent and country. ${liveTotal} live, more on the way.`}
  jsonLd={jsonLd}
>
  <section class="page-hero">
    <div class="wrap">
      <p class="eyebrow">Destinations</p>
      <h1>Explore the world by continent</h1>
      <p>We go deep on one country at a time — real places, honest advice, and the details that matter.</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      {continents.map((cont) => (
        <div class="region-group">
          <div class="rule-head"><a class="kicker" href={`/continents/${cont.slug}`}>{cont.name} →</a></div>
          <div class="country-grid">
            {cont.countries.map((c) => (
              c.count > 0 ? (
                <a class="country-card is-live" href={`/destinations/${c.slug}`}>
                  <div class="country-photo" style={`background-image:url(${repImage(c.name)})`}>
                    <span class="country-flag"><Icon name={`circle-flags:${c.iso2}`} /></span>
                  </div>
                  <div class="country-body">
                    <h3>{c.name}</h3>
                    <p>{c.blurb}</p>
                    <span class="country-meta">{c.count} guides →</span>
                  </div>
                </a>
              ) : (
                <div class="country-card is-soon">
                  <div class="country-photo"><span class="country-flag"><Icon name={`circle-flags:${c.iso2}`} /></span></div>
                  <div class="country-body">
                    <h3>{c.name}</h3>
                    <p>{c.blurb}</p>
                    <span class="country-meta">Coming soon</span>
                  </div>
                </div>
              )
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
