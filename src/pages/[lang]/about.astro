---
import { getEntry } from 'astro:content';
import StaticPage from '../../components/StaticPage.astro';
import type { Lang } from '../../i18n/utils';
export function getStaticPaths() {
  return (['ko', 'ja', 'es', 'zh'] as Lang[]).map((lang) => ({ params: { lang }, props: { lang } }));
}
const { lang } = Astro.props;
const entry = await getEntry('staticPages', 'about');
const translation = await getEntry('staticPagesI18n', `${lang}/about`);
---

<StaticPage entry={entry} translation={translation ?? null} lang={lang} />
