---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { SITE } from '../siteConfig';

const site = Astro.site?.toString().replace(/\/$/, '') ?? '';
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'CollectionPage', name: 'Flights', description: 'Search real-time flight prices to destinations around the world.', url: pageUrl, isPartOf: { '@id': `${site}/#site` } },
    { '@type': 'BreadcrumbList', itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site + '/' },
      { '@type': 'ListItem', position: 2, name: 'Flights', item: pageUrl },
    ] },
  ],
};
---

<BaseLayout
  title="Flights — Find real-time fares to anywhere"
  description={`Search live flight prices with ${SITE.name}. Pick your departure and destination and compare fares in your local currency.`}
  jsonLd={jsonLd}
>
  <section class="page-hero">
    <div class="wrap">
      <p class="eyebrow"><Icon name="ph:airplane-tilt" /> Fares</p>
      <h1>Find your flight</h1>
      <p>Search live prices across hundreds of airlines and agencies. Pick where you’re flying from and where you’re headed — fares show in your local currency.</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="tp-widget-card">
        <!-- Travelpayouts / Aviasales flight search form. IDs generated from our
             own dashboard: promo_id=7879 is the Flights Search Form for marker
             754088 (the old promo_id=4132 was wrong → "marker is not subscribed
             to campaign"). Colors match our site; show_hotels=false = flights-only. -->
        <script is:inline async src="https://tpemd.com/content?currency=usd&trs=553157&shmarker=754088&show_hotels=false&powered_by=true&locale=en&searchUrl=www.aviasales.com%2Fsearch&primary_override=%23c8443a&color_button=%23c8443a&color_icons=%23857c6f&dark=%23201c17&light=%23FFFFFF&secondary=%23f4eee3&special=%23e6e1d6&color_focused=%23c8443a&border_radius=10&plain=true&promo_id=7879&campaign_id=100" charset="utf-8"></script>
      </div>

      <div class="tp-flights-tips">
        <div>
          <h3>How it works</h3>
          <p>Enter your nearest airport and destination. We send you to the booking site with the best fare — you book there directly.</p>
        </div>
        <div>
          <h3>Prices in your currency</h3>
          <p>Fares are shown in the currency of the country you’re browsing from, so there’s no mental math at checkout.</p>
        </div>
        <div>
          <h3>Flexible dates save money</h3>
          <p>If your dates can move, try a few options — midweek departures are often meaningfully cheaper.</p>
        </div>
      </div>

      <p class="tp-disclosure">Some links on this page are affiliate links. If you book through them, {SITE.name} may earn a commission at no extra cost to you — it helps keep our guides free.</p>
    </div>
  </section>
</BaseLayout>
