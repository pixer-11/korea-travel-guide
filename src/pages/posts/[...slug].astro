---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Newsletter from '../../components/Newsletter.astro';
import Hotels from '../../components/Hotels.astro';
import Tours from '../../components/Tours.astro';
import PlanTrip from '../../components/PlanTrip.astro';
import StickyBook from '../../components/StickyBook.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const d = post.data;
const p = d.place;

// Country-aware values (this was a Korea-only template — everything below must
// derive from the post's country, not hardcode "Korea"/"KR"/"South Korea").
const country = d.country ?? 'South Korea';
const countrySlug = country.toLowerCase().replace(/\s+/g, '-');
const COUNTRY_ISO: Record<string, string> = {
  'South Korea': 'KR', Japan: 'JP', 'United States': 'US', Thailand: 'TH',
  France: 'FR', Italy: 'IT', China: 'CN', Spain: 'ES', Vietnam: 'VN',
  'United Arab Emirates': 'AE', Taiwan: 'TW', Indonesia: 'ID', Malaysia: 'MY',
  India: 'IN', Philippines: 'PH', Turkey: 'TR', Singapore: 'SG',
};
const countryISO = COUNTRY_ISO[country];

// Peak-intent affiliate links for the top "Book this trip" band (city-specific,
// correct attribution, work regardless of flight/hotel program approval).
const klookTop = `https://affiliate.klook.com/redirect?aid=api%7C13694%7C-754088%7Cpid%7C754088&k_site=${encodeURIComponent(`https://www.klook.com/en-US/search/?query=${d.region}`)}`;
const hotelTop = `https://search.hotellook.com/?marker=754088&destination=${encodeURIComponent(d.region)}`;
// Place-specific "get tickets" link for the fact box — only for ticketable
// categories, keyed to the venue name itself.
const ticketable = ['attraction', 'trendy', 'hidden-gem'].includes(d.category);
const klookPlace = p?.name
  ? `https://affiliate.klook.com/redirect?aid=api%7C13694%7C-754088%7Cpid%7C754088&k_site=${encodeURIComponent(`https://www.klook.com/en-US/search/?query=${p.name}`)}`
  : klookTop;

const priceLabels = ['Free', '₩', '₩₩', '₩₩₩', '₩₩₩₩'];
const stars = p?.rating ? '★'.repeat(Math.round(p.rating)) + '☆'.repeat(5 - Math.round(p.rating)) : null;
const updated = d.updatedDate ?? d.pubDate;

// Map our category to a schema.org place type (helps travel AI results).
const placeType =
  d.category === 'restaurant'
    ? 'Restaurant'
    : d.category === 'attraction' || d.category === 'trendy'
    ? 'TouristAttraction'
    : 'LocalBusiness';

const site = Astro.site?.toString().replace(/\/$/, '') ?? '';
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

// Related guides for internal linking (session depth + crawl equity). Score by
// same region (strong) then same category; stable tie-break so builds don't churn.
const related = (await getCollection('posts', ({ data }) => !data.draft))
  .filter((r) => r.id !== post.id)
  .map((r) => ({
    r,
    score: (r.data.region === d.region ? 2 : 0) + (r.data.category === d.category ? 1 : 0),
  }))
  .filter((x) => x.score > 0)
  .sort((a, b) => b.score - a.score || (b.r.data.pubDate > a.r.data.pubDate ? 1 : -1))
  .slice(0, 4)
  .map((x) => x.r);

// ---- Structured data graph (Article + Place + FAQ + Breadcrumbs) ----
const graph: Record<string, unknown>[] = [
  {
    '@type': 'Article',
    headline: d.title,
    description: d.description,
    datePublished: d.pubDate.toISOString(),
    dateModified: updated.toISOString(),
    image: d.heroImage?.url ? { '@type': 'ImageObject', url: new URL(d.heroImage.url, Astro.site).toString() } : undefined,
    author: { '@id': `${site}/#org` },
    publisher: { '@id': `${site}/#org` },
    isPartOf: { '@id': `${site}/#site` },
    inLanguage: 'en',
    mainEntityOfPage: pageUrl,
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site + '/' },
      { '@type': 'ListItem', position: 2, name: country, item: `${site}/destinations/${countrySlug}` },
      { '@type': 'ListItem', position: 3, name: d.region, item: `${site}/regions/${d.region.toLowerCase()}` },
      { '@type': 'ListItem', position: 4, name: d.title, item: pageUrl },
    ],
  },
];

if (p?.name) {
  graph.push({
    '@type': placeType,
    name: p.name,
    address: p.address
      ? { '@type': 'PostalAddress', streetAddress: p.address, ...(countryISO && { addressCountry: countryISO }) }
      : undefined,
    geo: p.lat && p.lng ? { '@type': 'GeoCoordinates', latitude: p.lat, longitude: p.lng } : undefined,
    // NOTE: we deliberately do NOT emit aggregateRating here. The rating is
    // Google's, not review data we host, so marking it up as our own would
    // violate Google's review-snippet policy (manual-action risk). We still
    // SHOW the rating on-page, clearly attributed to Google.
    priceRange: typeof p.priceLevel === 'number' ? priceLabels[p.priceLevel] : undefined,
    hasMap: p.googleMapsUrl,
  });
}

if (d.faq.length) {
  graph.push({
    '@type': 'FAQPage',
    mainEntity: d.faq.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  });
}

const jsonLd = { '@context': 'https://schema.org', '@graph': graph };
---

<BaseLayout
  title={d.title}
  description={d.description}
  image={d.heroImage?.url}
  article={true}
  jsonLd={jsonLd}
>
  <article class="article wrap">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a> <span>/</span>
      <a href={`/destinations/${countrySlug}`}>{country}</a> <span>/</span>
      <a href={`/regions/${d.region.toLowerCase()}`}>{d.region}</a> <span>/</span>
      <span aria-current="page">{d.category.replace('-', ' ')}</span>
    </nav>

    <div class="article-head">
      <div class="kicker">
        <span class="badge">{d.category.replace('-', ' ')}</span>
        <span>{d.region}</span>
        <span>·</span>
        <time datetime={updated.toISOString()}>
          {d.updatedDate ? 'Updated' : 'Published'} {updated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </div>
      <h1>{d.title}</h1>
      <p class="byline">
        By the <a href="/about">Wander Atlas editorial team</a> · AI-assisted, reviewed against live Google&nbsp;Places and official sources
      </p>
    </div>

    {d.heroImage && (
      <figure class="article-hero">
        <img src={d.heroImage.url} alt={p?.name ? `${p.name} in ${d.region}, ${country}` : `${(d.tags && d.tags[1]) || d.category} in ${d.region}, ${country}`} width="1200" height="675" loading="eager" fetchpriority="high" decoding="async" />
        {d.heroImage.credit && (
          <figcaption>
            {d.heroImage.source?.startsWith('http') ? (
              <a href={d.heroImage.source} target="_blank" rel="noopener nofollow">{d.heroImage.credit}</a>
            ) : d.heroImage.credit}
          </figcaption>
        )}
      </figure>
    )}

    {d.quickAnswer && (
      <aside class="quick-answer">
        <span class="qa-label">Quick answer</span>
        <p>{d.quickAnswer}</p>
      </aside>
    )}

    <div class="book-cta">
      <span class="book-cta-label">Planning a trip to {d.region}?</span>
      <div class="book-cta-btns">
        <a class="book-btn book-btn-primary" href={klookTop} target="_blank" rel="sponsored noopener">🎟️ Things to do</a>
        <a class="book-btn" href={hotelTop} target="_blank" rel="sponsored noopener">🏨 Find hotels</a>
      </div>
    </div>

    {p && (p.address || p.rating || p.priceLevel !== undefined) && (
      <div class="fact-box">
        <h4>At a glance</h4>
        <div class="fact-grid">
          {p.name && <div class="fact"><span class="k">Place</span><span class="v">{p.name}</span></div>}
          {p.address && <div class="fact"><span class="k">Address</span><span class="v">{p.address}</span></div>}
          {typeof p.rating === 'number' && (
            <div class="fact"><span class="k">Rating</span><span class="v"><span class="stars">{stars}</span> {p.rating}
              {p.userRatingsTotal ? ` (${p.userRatingsTotal.toLocaleString()})` : ''}</span></div>
          )}
          {typeof p.priceLevel === 'number' && <div class="fact"><span class="k">Price</span><span class="v">{priceLabels[p.priceLevel]}</span></div>}
        </div>
        <div class="fact-actions">
          {ticketable && p.name && (
            <a class="fact-ticket" href={klookPlace} target="_blank" rel="sponsored noopener">🎫 Tickets &amp; tours for {p.name}</a>
          )}
          {p.googleMapsUrl && (
            <a class="map-link" href={p.googleMapsUrl} target="_blank" rel="noopener">📍 Open in Google Maps</a>
          )}
        </div>
      </div>
    )}

    {!(p && p.googleMapsUrl) && d.region && (
      <p class="map-cta">
        <a
          class="map-link"
          href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(
            [p?.name, (d.tags && d.tags[1]) || d.category, d.region, country]
              .filter(Boolean)
              .join(' ')
          )}`}
          target="_blank"
          rel="noopener nofollow"
        >
          📍 Explore on Google Maps
        </a>
      </p>
    )}

    <div class="prose">
      <Content />
    </div>

    <Hotels city={d.region} country={d.country ?? 'South Korea'} />

    <Tours city={d.region} />

    <PlanTrip city={d.region} country={d.country ?? 'South Korea'} />

    {d.gallery.length > 0 && (
      <section class="gallery">
        {d.gallery.map((img) => (
          <figure>
            <img src={img.url} alt={d.place?.name ?? d.title} loading="lazy" />
            {img.credit && <figcaption>{img.credit}</figcaption>}
          </figure>
        ))}
      </section>
    )}

    {d.faq.length > 0 && (
      <section class="faq">
        <h2>Frequently asked questions</h2>
        {d.faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </section>
    )}

    {related.length > 0 && (
      <section class="related">
        <h2>Related guides</h2>
        <ul>
          {related.map((r) => (
            <li>
              <a href={`/posts/${r.id}`}>{r.data.title}</a>
              <span class="rel-region">{r.data.region}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    <Newsletter compact />

    <p class="disclosure">
      This guide was produced with AI assistance and reviewed against live data
      sources. Facts such as hours, ratings, and location come from Google Places;
      images are licensed or public domain. Details can change — please verify
      before visiting. See our <a href="/about">editorial policy</a>.
    </p>
  </article>

  <StickyBook city={d.region} place={p?.name} />
</BaseLayout>
