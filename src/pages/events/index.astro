---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import Newsletter from '../../components/Newsletter.astro';
import Flag from '../../components/Flag.astro';
import { SITE } from '../../siteConfig';
import { isEventPast, eventSortValue } from '../../lib/eventStatus';
import countriesData from '../../../data/countries.json';

const all = await getCollection('posts', ({ data }) => !data.draft && data.category === 'event');
const today = new Date();
const upcoming = all
  .filter((p) => !isEventPast(p.data, today))
  .sort((a, b) => eventSortValue(a.data, today) - eventSortValue(b.data, today));
const past = all
  .filter((p) => isEventPast(p.data, today))
  .sort((a, b) => eventSortValue(a.data, today) - eventSortValue(b.data, today));

const countries = new Set(upcoming.map((p) => p.data.country ?? 'South Korea')).size;

// "Browse by country" — link to each per-country events hub (built only for
// countries with ≥2 events). Ordered by upcoming-event count, then name.
const slugByName = new Map(countriesData.countries.map((c) => [c.name, c]));
const evCount = new Map();
for (const p of all) {
  const n = p.data.country ?? 'South Korea';
  evCount.set(n, (evCount.get(n) ?? 0) + 1);
}
const upCount = new Map();
for (const p of upcoming) {
  const n = p.data.country ?? 'South Korea';
  upCount.set(n, (upCount.get(n) ?? 0) + 1);
}
const countryLinks = [...evCount.entries()]
  .filter(([name, n]) => n >= 2 && slugByName.has(name))
  .map(([name]) => ({ name, slug: slugByName.get(name).slug, flag: slugByName.get(name).iso2, up: upCount.get(name) ?? 0 }))
  .sort((a, b) => b.up - a.up || a.name.localeCompare(b.name));

// Group upcoming events by month for a scannable, date-first layout.
const monthLabel = (d) =>
  d ? new Date(d).toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) : 'Date to be announced';
const byMonth = new Map();
for (const p of upcoming) {
  const k = p.data.eventStartDate ? monthLabel(p.data.eventStartDate) : 'Date to be announced';
  (byMonth.get(k) || byMonth.set(k, []).get(k)).push(p);
}

const card = (post) => ({
  href: `/posts/${post.id}`,
  title: post.data.title,
  description: post.data.description,
  region: `${post.data.region} · ${post.data.country ?? 'South Korea'}`,
  category: post.data.category,
  image: post.data.heroImage?.url,
  eventEndDate: post.data.eventEndDate,
});

const site = Astro.site?.toString().replace(/\/$/, '') ?? '';
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'CollectionPage', name: 'Upcoming Events', description: `Upcoming concerts, sports events and festivals worth traveling for.`, url: pageUrl, isPartOf: { '@id': `${site}/#site` } },
    { '@type': 'BreadcrumbList', itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site + '/' },
      { '@type': 'ListItem', position: 2, name: 'Events', item: pageUrl },
    ] },
    ...(upcoming.length ? [{ '@type': 'ItemList', itemListElement: upcoming.map((p, i) => ({ '@type': 'ListItem', position: i + 1, url: `${site}/posts/${p.id}`, name: p.data.title })) }] : []),
  ],
};
---

<BaseLayout
  title="Upcoming Events — Concerts, Sports & Festivals to Travel For"
  description={`${upcoming.length} upcoming concerts, sports events and festivals across ${countries} countries — dates, cities, and how to plan your trip around them.`}
  jsonLd={jsonLd}
>
  <section class="page-hero">
    <div class="wrap">
      <p class="eyebrow">Events</p>
      <h1>Upcoming events</h1>
      <p>{upcoming.length} upcoming concerts, sports events, and festivals across {countries} {countries === 1 ? 'country' : 'countries'} — pick a date, plan the trip around it.</p>
      {countryLinks.length > 1 && (
        <p class="event-country-nav">
          Browse by country:{' '}
          {countryLinks.map((c, i) => (
            <>{i > 0 && <span aria-hidden="true"> · </span>}<a href={`/events/${c.slug}`} class="rule-link"><Flag code={c.flag} size="1em" class="flag-ico" /> {c.name}</a></>
          ))}
        </p>
      )}
    </div>
  </section>

  {upcoming.length === 0 && (
    <section class="section"><div class="wrap"><div class="fact-box" style="text-align:center"><p>No upcoming events listed right now — check back soon.</p></div></div></section>
  )}

  {[...byMonth].map(([month, items]) => (
    <section class="section">
      <div class="wrap">
        <div class="rule-head"><span class="kicker">{month}</span></div>
        <div class="grid">
          {items.map((post) => <PostCard {...card(post)} />)}
        </div>
      </div>
    </section>
  ))}

  {past.length > 0 && (
    <section class="section band">
      <div class="wrap">
        <div class="rule-head"><span class="kicker">지난 이벤트 · Past events</span></div>
        <div class="grid">
          {past.map((post) => <PostCard {...card(post)} />)}
        </div>
      </div>
    </section>
  )}

  <Newsletter
    heading="Never miss an event worth traveling for"
    dek="New concerts, festivals, and sports events across our destinations — the moment we publish them. Unsubscribe anytime."
  />
</BaseLayout>
