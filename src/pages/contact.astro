---
import BaseLayout from '../layouts/BaseLayout.astro';

const contactEmail = 'hello@wanderatlasguides.com';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Wander Atlas — corrections, questions, and feedback."
>
  <div class="page-hero">
    <div class="wrap">
      <p class="eyebrow">Get in touch</p>
      <h1>Contact us</h1>
      <p>Corrections, questions, or feedback — we'd love to hear from you.</p>
    </div>
  </div>

  <article class="article wrap">
    <div class="prose">
      <p>
        Spotted something out of date, or have a question about planning a trip?
        Places close and prices change, and we genuinely want to keep our guides
        accurate — so please tell us.
      </p>

      <div class="fact-box">
        <h4>Email</h4>
        <p><a href={`mailto:${contactEmail}`}>{contactEmail}</a></p>
      </div>

      <p class="disclosure">
        We aim to reply to genuine questions and corrections. This is an
        informational travel site — for emergencies while traveling, always use
        the local emergency number for the country you're in.
      </p>
    </div>
  </article>
</BaseLayout>
