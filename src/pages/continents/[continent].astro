---
import { getCollection } from 'astro:content';
import ContinentHub from '../../components/ContinentHub.astro';
import countriesData from '../../../data/countries.json';

// One static page per continent that has any country in the data.
export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  const countFor = (name) => posts.filter((p) => (p.data.country ?? 'South Korea') === name).length;
  const slugify = (name) => name.toLowerCase().replace(/\s+/g, '-');

  const byContinent = {};
  for (const c of countriesData.countries) {
    (byContinent[c.continent || 'Other'] ||= []).push({ ...c, count: countFor(c.name) });
  }
  return Object.entries(byContinent).map(([name, countries]) => ({
    params: { continent: slugify(name) },
    props: {
      continentName: name,
      countries: countries.sort((a, b) => b.count - a.count || a.name.localeCompare(b.name)),
    },
  }));
}

const { continentName, countries } = Astro.props;
---

<ContinentHub continentName={continentName} countries={countries} lang="en" />
