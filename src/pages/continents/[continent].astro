---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Flag from '../../components/Flag.astro';
import { SITE } from '../../siteConfig';
import { pickRepHeroUrl } from '../../lib/repImage';
import countriesData from '../../../data/countries.json';

const CONTINENT_ORDER = ['Asia', 'Europe', 'North America', 'South America', 'Africa', 'Oceania', 'Other'];
const CONTINENT_EMOJI = { Asia: '🌏', Europe: '🌍', 'North America': '🌎', 'South America': '🌎', Africa: '🌍', Oceania: '🌏', Other: '🗺️' };
const contSlug = (name) => name.toLowerCase().replace(/\s+/g, '-');

// One static page per continent that has any country in the data.
export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  const countFor = (name) => posts.filter((p) => (p.data.country ?? 'South Korea') === name).length;
  const slugify = (name) => name.toLowerCase().replace(/\s+/g, '-');

  const byContinent = {};
  for (const c of countriesData.countries) {
    (byContinent[c.continent || 'Other'] ||= []).push({ ...c, count: countFor(c.name) });
  }
  return Object.entries(byContinent).map(([name, countries]) => ({
    params: { continent: slugify(name) },
    props: {
      continentName: name,
      countries: countries.sort((a, b) => b.count - a.count || a.name.localeCompare(b.name)),
    },
  }));
}

const { continentName, countries } = Astro.props;
const liveCount = countries.filter((c) => c.count > 0).length;
const guideTotal = countries.reduce((n, c) => n + c.count, 0);
const emoji = CONTINENT_EMOJI[continentName] ?? '🗺️';

// A representative photo for the continent hero — newest real post image from
// any country in this continent.
const posts = await getCollection('posts', ({ data }) => !data.draft);
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const names = new Set(countries.map((c) => c.name));
const heroPost = posts.find(
  (p) => names.has(p.data.country ?? 'South Korea') && p.data.heroImage?.url && !p.data.heroImage.url.includes('placeholder')
);
const heroImg = heroPost?.data.heroImage?.url ?? '';

// A representative photo per country — its newest real (non-placeholder) hero.
const repImage = (name) => pickRepHeroUrl(posts.filter((p) => (p.data.country ?? 'South Korea') === name));

const site = Astro.site?.toString().replace(/\/$/, '') ?? '';
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'CollectionPage', name: `${continentName} travel guides`, description: `Travel guides for countries in ${continentName}.`, url: pageUrl, isPartOf: { '@id': `${site}/#site` } },
    { '@type': 'BreadcrumbList', itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site + '/' },
      { '@type': 'ListItem', position: 2, name: 'Destinations', item: `${site}/destinations` },
      { '@type': 'ListItem', position: 3, name: continentName, item: pageUrl },
    ] },
  ],
};
---

<BaseLayout
  title={`${continentName} — Travel Guides by Country`}
  description={`Explore ${SITE.name}'s travel guides across ${continentName} — ${liveCount} ${liveCount === 1 ? 'country' : 'countries'} live${guideTotal ? `, ${guideTotal} guides` : ''} and growing.`}
  image={heroImg || undefined}
  jsonLd={jsonLd}
>
  <section class:list={['page-hero', { 'page-hero--photo': heroImg }]} style={heroImg ? `background-image:linear-gradient(180deg,rgba(20,20,25,.55),rgba(20,20,25,.78)),url(${heroImg});background-size:cover;background-position:center;` : ''}>
    <div class="wrap">
      <p class="eyebrow"><a href="/destinations">Destinations</a> · {emoji} Continent</p>
      <h1>{continentName}</h1>
      <p>{liveCount > 0 ? `${liveCount} ${liveCount === 1 ? 'country' : 'countries'} live${guideTotal ? ` · ${guideTotal} guides` : ''} — pick a country to start exploring.` : 'Guides for this continent are on the way.'}</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="country-grid">
        {countries.map((c) => (
          c.count > 0 ? (
            <a class="country-card is-live" href={`/destinations/${c.slug}`}>
              <div class="country-photo" style={`background-image:url(${repImage(c.name)})`}>
                <span class="country-flag"><Flag code={c.iso2} /></span>
              </div>
              <div class="country-body">
                <h3>{c.name}</h3>
                <p>{c.blurb}</p>
                <span class="country-meta">{c.count} guides →</span>
              </div>
            </a>
          ) : (
            <div class="country-card is-soon">
              <div class="country-photo"><span class="country-flag"><Flag code={c.iso2} /></span></div>
              <div class="country-body">
                <h3>{c.name}</h3>
                <p>{c.blurb}</p>
                <span class="country-meta">Coming soon</span>
              </div>
            </div>
          )
        ))}
      </div>

      <p class="continent-back"><a href="/destinations">← All continents</a></p>
    </div>
  </section>
</BaseLayout>
