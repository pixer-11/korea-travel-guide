---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EssentialsCountryIndex from '../../components/EssentialsCountryIndex.astro';

const site = Astro.site?.toString().replace(/\/$/, '') ?? '';
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

const faq = [
  {
    q: 'Should I get a transit card?',
    a: 'In most major cities, yes — a rechargeable tap card is the cheapest, easiest way to ride subways, buses, and often taxis (Korea’s T-money, Japan’s Suica/ICOCA, London’s Oyster, Singapore’s EZ-Link, Hong Kong’s Octopus). Buy one at a station or convenience store on arrival and top it up with cash. See each country guide below for the local card.',
  },
  {
    q: 'Which map app should I use abroad?',
    a: 'Google Maps works well for transit in most countries, but a few need local apps — Korea uses Naver Map or Kakao Map, and mainland China needs a local app or VPN. Each country guide notes the right one and the local ride-hailing app (Grab, Kakao T, DiDi, Uber, etc.).',
  },
  {
    q: 'What’s the best way in from the airport?',
    a: 'Big airports usually have a fast rail link or official airport bus that’s far cheaper than a taxi (Seoul’s AREX, Tokyo’s Narita Express, Hong Kong’s Airport Express). Grab your transit card at the airport first. The per-country guides list the specific options.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'WebPage', name: 'Getting Around: Transport Guide by Country', description: 'Transit cards, subways, intercity trains, taxis, and airport transfers for international travelers, with per-country guides.', url: pageUrl, isPartOf: { '@id': `${site}/#site` } },
    { '@type': 'BreadcrumbList', itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site + '/' },
      { '@type': 'ListItem', position: 2, name: 'Getting around', item: pageUrl },
    ] },
    { '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  ],
};
---

<BaseLayout
  title="Getting Around: Transport Guide by Country"
  description="Transit cards, subways, intercity trains, taxis, ride apps, and airport transfers — the practical basics, plus a guide for each destination."
  jsonLd={jsonLd}
>
  <div class="page-hero">
    <div class="wrap">
      <p class="eyebrow">Essentials</p>
      <h1>Getting around</h1>
      <p>The transport basics that apply almost anywhere — then pick your destination.</p>
    </div>
  </div>

  <article class="article wrap">
    <aside class="quick-answer">
      <span class="qa-label">Quick answer</span>
      <p>
        In most cities: grab a <strong>rechargeable transit card</strong> on
        arrival and tap it on subways, buses, and often taxis. Navigate with
        <strong>Google Maps</strong> (or the local app where it’s weak, like Naver/
        Kakao in Korea), use the local <strong>ride-hailing app</strong>, and take
        <strong>high-speed rail</strong> between big cities. Each country guide below
        has the specifics.
      </p>
    </aside>

    <div class="prose">
      <h2>Transit cards</h2>
      <p>
        Almost every major destination has one rechargeable tap card that covers the
        subway, city buses, and sometimes taxis and convenience stores — T-money in
        Korea, Suica/ICOCA in Japan, Oyster in London, EZ-Link in Singapore, Octopus
        in Hong Kong. Buy it at a station or convenience store when you land, load it
        with cash, and you’ve unlocked the cheapest way around town.
      </p>

      <h2>City subways &amp; buses</h2>
      <p>
        Big cities usually have clean, frequent, English-signed metro systems and
        extensive bus networks. Fares are distance-based and low. The main gotcha is
        navigation: Google Maps transit is excellent in most countries but weak in a
        few (use Naver Map or Kakao Map in Korea), so check your destination’s guide.
      </p>

      <h2>Between cities</h2>
      <p>
        Where it exists, <strong>high-speed rail</strong> is usually the best way
        between major cities — comfortable, central-to-central, and often faster than
        flying once you count airport time (Korea’s KTX, Japan’s Shinkansen, Europe’s
        TGV/Frecciarossa). Intercity buses reach smaller towns the train doesn’t.
      </p>

      <h2>Taxis &amp; ride-hailing</h2>
      <p>
        A local ride-hailing app usually beats flagging a cab for price transparency
        and to avoid language barriers over your destination — Kakao T in Korea, Grab
        across Southeast Asia, DiDi in China, Uber/Bolt in much of Europe and the
        Americas. The country guides note which one works where you’re going.
      </p>

      <h2>Airport transfers</h2>
      <p>
        Most large airports have a dedicated rail link or official airport bus that’s
        far cheaper than a taxi into town. Buy your transit card at the airport first,
        then take the train or bus. See the per-country guide for the exact option.
      </p>
    </div>

    <EssentialsCountryIndex heading="Getting around, by country" />

    <section class="faq">
      <h2>Frequently asked questions</h2>
      {faq.map((f) => (
        <details>
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </section>

    <p class="disclosure">
      Fares, apps, and schedules vary by country and change over time — the country
      guides above give each destination’s specifics and official apps/sites. Confirm
      before you travel.
    </p>
  </article>
</BaseLayout>
