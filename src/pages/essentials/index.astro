---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Emoji from '../../components/Emoji.astro';
import EssentialsCountryIndex from '../../components/EssentialsCountryIndex.astro';

const site = Astro.site?.toString().replace(/\/$/, '') ?? '';
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

// Reuse only emoji names already in the extracted subset (build-emoji-data.mjs)
// to avoid the Cloudflare build OOM history.
const topics = [
  { href: '/essentials/visa', icon: 'passport-control', h: 'Visa & entry', p: 'Entry rules, visas, and arrival cards.' },
  { href: '/essentials/transport', icon: 'metro', h: 'Getting around', p: 'Transit passes, trains, and city map apps.' },
  { href: '/essentials/money', icon: 'credit-card', h: 'Money & costs', p: 'Cards vs cash, ATMs, tipping, tax refunds.' },
  { href: '/essentials/best-time-to-visit', icon: 'cherry-blossom', h: 'Best time to visit', p: 'Seasons, weather, and festivals.' },
  { href: '/essentials/emergency', icon: 'police-car-light', h: 'Emergency & help', p: 'Emergency numbers and traveler hotlines.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'CollectionPage', name: 'Travel Essentials', description: 'Know-before-you-go travel essentials — visa & entry, getting around, money, best time to visit, and emergencies — by topic and by country.', url: pageUrl, isPartOf: { '@id': `${site}/#site` } },
    { '@type': 'BreadcrumbList', itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site + '/' },
      { '@type': 'ListItem', position: 2, name: 'Travel essentials', item: pageUrl },
    ] },
  ],
};
---

<BaseLayout
  title="Travel Essentials — Visa, Transport, Money & More"
  description="Know before you go: visa & entry, getting around, money, best time to visit, and emergency numbers — by topic, and for every destination we cover."
  jsonLd={jsonLd}
>
  <div class="page-hero">
    <div class="wrap">
      <p class="eyebrow">Essentials</p>
      <h1>Travel essentials</h1>
      <p>The practical know-before-you-go — pick a topic, or jump to your destination.</p>
    </div>
  </div>

  <section class="section">
    <div class="wrap">
      <div class="essentials-strip">
        {topics.map((t) => (
          <a class="essential-card" href={t.href}>
            <span class="ico"><Emoji name={t.icon} /></span>
            <div><h3>{t.h}</h3><p>{t.p}</p></div>
          </a>
        ))}
      </div>

      <EssentialsCountryIndex heading="Essentials by country" />
    </div>
  </section>
</BaseLayout>
