---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EssentialsCountryIndex from '../../components/EssentialsCountryIndex.astro';

const site = Astro.site?.toString().replace(/\/$/, '') ?? '';
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

const faq = [
  {
    q: 'Do I need a visa to travel abroad?',
    a: 'It depends on your nationality AND your destination. Many countries let visitors from the US, UK, EU, Canada, Australia and Japan enter visa-free for short tourist stays (commonly 30–90 days); others require a visa or an e-visa in advance. Always confirm your own passport against the destination’s official immigration portal — see the per-country guides below.',
  },
  {
    q: 'What is an ETA / eTA?',
    a: 'An Electronic Travel Authorization is an online pre-approval that some countries require from visa-free visitors before they travel (for example Korea’s K-ETA, the US ESTA, or the upcoming EU ETIAS). It is not a visa. Apply on the official government site well before departure — never through look-alike paid agents.',
  },
  {
    q: 'What is a digital arrival card?',
    a: 'Many countries have replaced the old paper landing card with an online “arrival card” you complete a few days before you land (Korea’s e-Arrival Card, Thailand’s TDAC, Singapore’s SG Arrival Card, and others). Being visa-free or ETA-exempt usually does NOT exempt you from it. Check the destination’s official portal.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      name: 'Visa & Entry Requirements by Country',
      description: 'How visas, ETAs, and digital arrival cards work for international travel, with per-country guides and official sources.',
      url: pageUrl,
      isPartOf: { '@id': `${site}/#site` },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: site + '/' },
        { '@type': 'ListItem', position: 2, name: 'Visa & Entry', item: pageUrl },
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: faq.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};
---

<BaseLayout
  title="Visa & Entry Requirements by Country"
  description="How visas, ETAs, and digital arrival cards work — plus per-country entry guides and the official sources to confirm your case."
  jsonLd={jsonLd}
>
  <div class="page-hero">
    <div class="wrap">
      <p class="eyebrow">Essentials</p>
      <h1>Visa & entry requirements</h1>
      <p>How entry works in general — then pick your destination for the specifics.</p>
    </div>
  </div>

  <article class="article wrap">
    <aside class="quick-answer">
      <span class="qa-label">Quick answer</span>
      <p>
        Whether you need a visa depends on your <strong>nationality</strong> and
        your <strong>destination</strong>. Many travelers get visa-free entry for
        30–90 days, but some countries also require an <strong>ETA</strong>
        (electronic pre-approval) and/or a <strong>digital arrival card</strong>
        submitted before you land. Rules change often — confirm your case on the
        official portal for your destination below.
      </p>
    </aside>

    <div class="prose">
      <blockquote>
        Visa and entry rules change frequently and depend on your nationality.
        This is general information, not immigration advice — always confirm with
        an official government source before you book.
      </blockquote>

      <h2>Visa-free, visa on arrival, or apply ahead?</h2>
      <p>
        Most countries fall into three buckets for a given passport: <strong>visa-free</strong>
        for a set number of days (often 30, 60, or 90), <strong>visa on arrival</strong>
        (you pay and get a stamp at the airport), or <strong>apply in advance</strong>
        (an embassy visa or an online e-visa). Which bucket you’re in depends
        entirely on your nationality, so check the destination’s official
        immigration portal before booking flights.
      </p>

      <h2>ETAs — pre-approval for visa-free visitors</h2>
      <p>
        Several countries ask even visa-free visitors to get an <strong>Electronic
        Travel Authorization</strong> before departure — Korea’s K-ETA, the US
        ESTA, and the upcoming EU ETIAS are examples. It’s a quick online form, not
        a visa. Apply early on the <em>official</em> government site and avoid
        look-alike paid agents that charge extra.
      </p>

      <h2>Digital arrival cards</h2>
      <p>
        The paper landing card is disappearing. Many destinations now use an online
        <strong>arrival card</strong> you complete a few days before you land, with
        your passport, flight, and accommodation address. Being visa-free or
        ETA-exempt usually does not exempt you from it — check whether your
        destination requires one.
      </p>
    </div>

    <EssentialsCountryIndex heading="Entry requirements by country" />

    <section class="faq">
      <h2>Frequently asked questions</h2>
      {faq.map((f) => (
        <details>
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </section>

    <p class="disclosure">
      We deliberately don’t list every per-country rule on this page because they
      change frequently — the country guides above summarize each destination and
      link its official sources. This is general information, not immigration advice.
    </p>
  </article>
</BaseLayout>
