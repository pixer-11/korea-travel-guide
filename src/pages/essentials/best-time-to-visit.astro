---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EssentialsCountryIndex from '../../components/EssentialsCountryIndex.astro';

const site = Astro.site?.toString().replace(/\/$/, '') ?? '';
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

const faq = [
  {
    q: 'How do I choose the best time to visit somewhere?',
    a: 'Weigh three things: weather (temperate places have spring/autumn sweet spots; tropical ones split into dry and rainy seasons), crowds and prices (peak season is busiest and dearest), and specific draws like cherry blossoms, autumn foliage, or a festival. The per-country guides below give each destination’s ideal months.',
  },
  {
    q: 'What is “shoulder season” and is it worth it?',
    a: 'Shoulder season is the stretch just before or after peak — often the best value. You get decent weather with noticeably smaller crowds and lower flight/hotel prices (for example late spring or early autumn in much of the northern hemisphere). Great if you’re flexible.',
  },
  {
    q: 'When is the cheapest time to travel?',
    a: 'Usually the off-season, avoiding school holidays, major local festivals, and the weather peak. Flights and hotels drop most when demand does — but check WHY a season is quiet (monsoon, extreme heat or cold) so cheaper doesn’t mean miserable. See each country guide.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'WebPage', name: 'Best Time to Visit: When to Go, by Country', description: 'How seasons, weather, crowds, and festivals shape the best time to travel, with the ideal months for each destination.', url: pageUrl, isPartOf: { '@id': `${site}/#site` } },
    { '@type': 'BreadcrumbList', itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site + '/' },
      { '@type': 'ListItem', position: 2, name: 'Best time to visit', item: pageUrl },
    ] },
    { '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  ],
};
---

<BaseLayout
  title="Best Time to Visit: When to Go, by Country"
  description="How seasons, weather, crowds, and festivals shape the best time to travel — plus the ideal months for each destination we cover."
  jsonLd={jsonLd}
>
  <div class="page-hero">
    <div class="wrap">
      <p class="eyebrow">Essentials</p>
      <h1>Best time to visit</h1>
      <p>How to read the seasons anywhere — then check your destination’s months.</p>
    </div>
  </div>

  <article class="article wrap">
    <aside class="quick-answer">
      <span class="qa-label">Quick answer</span>
      <p>
        The best time to travel balances <strong>weather</strong>, <strong>crowds &amp;
        price</strong>, and any <strong>seasonal highlight</strong> (blossoms, foliage,
        a festival). Temperate destinations usually shine in <strong>spring and
        autumn</strong>; tropical ones split into a <strong>dry season</strong> (best)
        and a rainy one. Each country guide below names the ideal months.
      </p>
    </aside>

    <div class="prose">
      <h2>Read the climate first</h2>
      <p>
        Temperate destinations (much of Korea, Japan, Europe, the US) have four seasons,
        and the sweet spots are typically <strong>spring and autumn</strong> — mild, dry,
        and scenic. Tropical and monsoon destinations (Thailand, Vietnam, Indonesia,
        much of India) instead have a <strong>dry season</strong> and a <strong>rainy
        season</strong>; the dry months are usually the comfortable time to go.
      </p>

      <h2>Peak, shoulder, and off-season</h2>
      <p>
        Peak season has the best weather but the biggest crowds and highest prices.
        <strong>Shoulder season</strong> — just before or after the peak — is often the
        smart choice: good conditions, thinner crowds, better value. The off-season is
        cheapest, but check <em>why</em> it’s quiet (monsoon, extreme heat or cold) before
        you book.
      </p>

      <h2>Time it to a highlight</h2>
      <p>
        Some trips are worth planning around a specific moment — <strong>cherry
        blossoms</strong> (roughly late March–April across Korea and Japan), <strong>autumn
        foliage</strong> (late October–November), or a major <strong>festival</strong>.
        These dates shift a little each year with the weather, so check a current forecast
        close to your trip, and browse our <a href="/events">upcoming events</a> for
        dated highlights.
      </p>
    </div>

    <EssentialsCountryIndex heading="Best time to visit, by country" />

    <section class="faq">
      <h2>Frequently asked questions</h2>
      {faq.map((f) => (
        <details>
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </section>

    <p class="disclosure">
      Bloom, foliage, and festival dates shift each year with the weather, and “best”
      depends on what you want — the country guides above give each destination’s typical
      ideal months. Check a current-year forecast close to your trip.
    </p>
  </article>
</BaseLayout>
