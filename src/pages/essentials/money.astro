---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EssentialsCountryIndex from '../../components/EssentialsCountryIndex.astro';

const site = Astro.site?.toString().replace(/\/$/, '') ?? '';
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

const faq = [
  {
    q: 'Cards or cash abroad?',
    a: 'It varies a lot by country. Korea, Northern Europe and Singapore are almost cashless, while parts of Japan, Germany and Southeast Asian markets still run on cash. A good rule: carry a contactless card plus modest local cash for markets, small eateries and rural areas. Each country guide below says how card-friendly your destination is.',
  },
  {
    q: 'How do I avoid bad exchange rates and ATM fees?',
    a: 'Use bank ATMs (or ones labelled for foreign/“Global” cards), and when a machine or terminal offers to charge you in your HOME currency, always decline and choose the LOCAL currency — “dynamic currency conversion” hides a poor rate. A no-foreign-fee debit/credit card saves the most.',
  },
  {
    q: 'Do I need to tip?',
    a: 'Tipping norms differ sharply: expected (15–20%) in the US, small rounding-up in much of Europe, and not customary at all in Korea and Japan where the marked price is what you pay. Check the per-country guide so you neither under- nor over-tip.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'WebPage', name: 'Money & Costs: Cards, Cash & Tipping by Country', description: 'Local currency, cards vs cash, ATMs and exchange, tipping, and tax refunds for international travelers, with per-country guides.', url: pageUrl, isPartOf: { '@id': `${site}/#site` } },
    { '@type': 'BreadcrumbList', itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site + '/' },
      { '@type': 'ListItem', position: 2, name: 'Money & costs', item: pageUrl },
    ] },
    { '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  ],
};
---

<BaseLayout
  title="Money & Costs: Cards, Cash & Tipping by Country"
  description="Local currency, cards vs cash, ATMs and exchange, tipping norms, and tourist tax refunds — the money basics, plus a guide for each destination."
  jsonLd={jsonLd}
>
  <div class="page-hero">
    <div class="wrap">
      <p class="eyebrow">Essentials</p>
      <h1>Money & costs</h1>
      <p>How to pay, tip, and avoid bad rates — then check your destination.</p>
    </div>
  </div>

  <article class="article wrap">
    <aside class="quick-answer">
      <span class="qa-label">Quick answer</span>
      <p>
        Carry a <strong>contactless card</strong> plus modest <strong>local cash</strong>
        for markets and small eateries. Withdraw from bank/“Global” ATMs, and always
        pay in the <strong>local currency</strong> (decline “charge in your home
        currency”). <strong>Tipping</strong> ranges from expected (US) to none at all
        (Korea, Japan) — see your destination’s guide.
      </p>
    </aside>

    <div class="prose">
      <h2>Local currency</h2>
      <p>
        Every destination has its own currency and price level — a coffee that’s a few
        dollars in one country is a fraction of that in another. Check a live exchange
        rate before you go rather than trusting airport boards, and learn the rough
        value of the local notes so prices sanity-check at a glance. Each country guide
        names the currency and typical costs.
      </p>

      <h2>Cards vs cash</h2>
      <p>
        Card and contactless acceptance varies enormously: some countries (Korea,
        Sweden, Singapore) are effectively cashless, while others still lean on cash for
        markets, taxis, temples, and small family-run places. The safe approach almost
        everywhere is a contactless card for shops and restaurants plus a modest cash
        buffer for the places that don’t take plastic.
      </p>

      <h2>ATMs &amp; exchange</h2>
      <p>
        Withdraw local cash from bank ATMs or ones marked for foreign/“Global” cards,
        which usually offer an English menu. The big money-saver: when an ATM or card
        terminal offers to bill you in your <em>home</em> currency, decline and choose
        the <strong>local</strong> currency — the “convenience” conversion bakes in a
        poor rate. A card with no foreign-transaction fee helps most.
      </p>

      <h2>Tipping &amp; tax refunds</h2>
      <p>
        Tipping is cultural, not universal — generous in the US, light in much of
        Europe, and simply not done in Korea or Japan. Many countries also offer
        <strong>tax-free shopping</strong>: keep receipts above the threshold and claim
        the VAT/GST refund at the airport before departure. The per-country guide spells
        out both.
      </p>
    </div>

    <EssentialsCountryIndex heading="Money & costs, by country" />

    <section class="faq">
      <h2>Frequently asked questions</h2>
      {faq.map((f) => (
        <details>
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </section>

    <p class="disclosure">
      Exchange rates, tipping norms, and tax-refund thresholds vary by country and
      change over time — the country guides above give each destination’s specifics.
      Check current rates before you travel.
    </p>
  </article>
</BaseLayout>
