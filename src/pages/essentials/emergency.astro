---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EssentialsCountryIndex from '../../components/EssentialsCountryIndex.astro';

const site = Astro.site?.toString().replace(/\/$/, '') ?? '';
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

const faq = [
  {
    q: 'What’s the emergency number where I’m going?',
    a: 'It varies by country, so check before you travel. 112 is the standard across the EU and works on most GSM phones worldwide; 911 covers the US and Canada; the UK uses 999; and many countries have separate police/fire/ambulance numbers plus a tourist hotline. Each country guide below lists the exact numbers.',
  },
  {
    q: 'Does 112 really work everywhere?',
    a: '112 is the single European emergency number and, thanks to the GSM standard, can often be dialed on a mobile even with no local SIM or a locked keypad — it routes to local services. But it isn’t universal, so always confirm your destination’s actual emergency numbers rather than assuming.',
  },
  {
    q: 'Do I need travel insurance?',
    a: 'Strongly recommended. In most countries foreign visitors pay out of pocket for medical care, and a serious problem or evacuation can be very expensive. Buy a policy that covers medical treatment and repatriation before you travel, and keep the emergency assistance number with you.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'WebPage', name: 'Emergency Numbers & Safety by Country', description: 'How emergency numbers work abroad (112, 911, local hotlines), medical care, insurance, and safety basics, with per-country numbers.', url: pageUrl, isPartOf: { '@id': `${site}/#site` } },
    { '@type': 'BreadcrumbList', itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site + '/' },
      { '@type': 'ListItem', position: 2, name: 'Emergency & safety', item: pageUrl },
    ] },
    { '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  ],
};
---

<BaseLayout
  title="Emergency Numbers & Safety by Country"
  description="How emergency numbers work abroad — 112, 911, and local tourist hotlines — plus medical, insurance, and safety basics, with the exact numbers for each destination."
  jsonLd={jsonLd}
>
  <div class="page-hero">
    <div class="wrap">
      <p class="eyebrow">Essentials</p>
      <h1>Emergency & safety</h1>
      <p>Save your destination’s emergency numbers before you go.</p>
    </div>
  </div>

  <article class="article wrap">
    <aside class="quick-answer">
      <span class="qa-label">Quick answer</span>
      <p>
        Emergency numbers differ by country — look yours up before you travel.
        <strong>112</strong> is the EU standard and works on most mobiles worldwide;
        <strong>911</strong> covers North America; the <strong>UK</strong> uses 999.
        Many destinations also run a <strong>tourist hotline</strong> with English help
        (Korea’s 1330, Thailand’s 1155). Get <strong>travel insurance</strong> — visitors
        usually pay for medical care out of pocket.
      </p>
    </aside>

    <div class="prose">
      <h2>Know the local numbers</h2>
      <p>
        There’s no single worldwide emergency number, so save your destination’s before
        you land. <strong>112</strong> works across the EU and on most GSM phones (often
        even without a local SIM); <strong>911</strong> is North America; <strong>999</strong>
        the UK; and many countries split police, fire, and ambulance across separate
        numbers. Several also offer a multilingual <strong>tourist hotline</strong> that
        can interpret and relay to emergency services. The country guides below list the
        exact numbers.
      </p>

      <h2>Medical care &amp; insurance</h2>
      <p>
        For a serious emergency, call the local ambulance number. For minor issues,
        pharmacies handle common ailments almost everywhere, and big cities usually have
        clinics or hospitals with English-speaking staff. Crucially, <strong>most
        countries make foreign visitors pay out of pocket</strong> — buy travel insurance
        covering medical treatment and evacuation before you go, and keep the assistance
        number handy.
      </p>

      <h2>Staying safe</h2>
      <p>
        Normal precautions travel well anywhere: watch your belongings in crowds, use
        licensed taxis or a trusted ride-hailing app, keep a <strong>copy of your
        passport</strong> separate from the original, and note your <strong>embassy or
        consulate</strong> contact in case you lose documents or need help. Check your
        government’s travel advisory for the destination before you book.
      </p>
    </div>

    <EssentialsCountryIndex heading="Emergency numbers by country" />

    <section class="faq">
      <h2>Frequently asked questions</h2>
      {faq.map((f) => (
        <details>
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </section>

    <p class="disclosure">
      This is general safety information, not medical or legal advice. Emergency numbers
      vary by country — confirm your destination’s in the country guides above, and in a
      real emergency call the local number immediately.
    </p>
  </article>
</BaseLayout>
