---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const items = await getCollection('essentials', ({ data }) => !data.draft);
  return items.map((entry) => ({ params: { country: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const reviewed = d.lastReviewed.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const site = Astro.site?.toString().replace(/\/$/, '') ?? '';
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'WebPage', name: d.title, description: d.description, url: pageUrl, dateModified: d.lastReviewed.toISOString(), isPartOf: { '@id': `${site}/#site` } },
    { '@type': 'BreadcrumbList', itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site + '/' },
      { '@type': 'ListItem', position: 2, name: d.country, item: `${site}/destinations/${entry.id}` },
      { '@type': 'ListItem', position: 3, name: 'Essentials', item: pageUrl },
    ] },
  ],
};
---

<BaseLayout title={d.title} description={d.description} jsonLd={jsonLd}>
  <div class="page-hero">
    <div class="wrap">
      <p class="eyebrow">Essentials · {d.country}</p>
      <h1>Know before you go: {d.country}</h1>
      <p>Visa & entry, getting around, money, best time, and emergencies — with official sources.</p>
    </div>
  </div>

  <article class="article wrap">
    <blockquote>
      This is a plain-English summary, not legal or medical advice. Entry and visa
      rules change — always confirm on the official sources linked below before you
      book or fly. <strong>Last reviewed: {reviewed}.</strong>
    </blockquote>

    <div class="prose">
      <Content />
    </div>

    <p class="disclosure">
      AI-assisted and web-researched, reviewed against official sources on
      {reviewed}. Rules and prices change — verify on the official links above.
      See our <a href="/about">editorial policy</a>.
    </p>
  </article>
</BaseLayout>
