---
import { getCollection } from 'astro:content';
import EssentialsCountryHub from '../../components/EssentialsCountryHub.astro';

export async function getStaticPaths() {
  const items = await getCollection('essentials', ({ data }) => !data.draft);
  return items.map((entry) => ({ params: { country: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
---

<EssentialsCountryHub entry={entry} translation={null} lang="en" />
