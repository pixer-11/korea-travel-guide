---
// Self-hosted variable fonts (no CDN, no external requests).
import '@fontsource-variable/fraunces'; // display serif
import '@fontsource-variable/inter'; // body sans
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../siteConfig';
import { getLangFromUrl, localeCodes, localizePath, stripLocale, type Lang } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  image?: string;
  article?: boolean;
  jsonLd?: Record<string, unknown>;
  // Set on pages that have a translated version at every locale, so we emit
  // hreflang alternates. Leave false for English-only pages.
  localized?: boolean;
  // Set on low-value pages (e.g. a one-off event that has already ended) to keep
  // the URL live but out of the index — avoids thin/outdated pages dragging the
  // young domain's overall quality. Recurring events stay indexed.
  noindex?: boolean;
}

const { title, description, image, article = false, jsonLd, localized = false, noindex = false } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const htmlLang = localeCodes[lang];
const canonical = new URL(Astro.url.pathname, Astro.site);
// hreflang alternates (localized pages only). x-default points to English.
const canonicalPath = stripLocale(Astro.url.pathname);
const alternates = localized
  ? (['en', 'ko', 'ja', 'es', 'zh'] as Lang[]).map((l) => ({
      hreflang: localeCodes[l],
      href: new URL(localizePath(canonicalPath, l), Astro.site).toString(),
    }))
  : [];
const ogImage = image ? new URL(image, Astro.site) : undefined;
const siteName = SITE.name;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';

// Sitewide entity graph — establishes the brand as a recognized entity,
// which 2026 AI search rewards with far higher citation/click rates.
const orgLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteUrl}/#org`,
      name: siteName,
      url: siteUrl,
      logo: { '@type': 'ImageObject', url: `${siteUrl}/favicon.svg` },
      description: 'Editor-reviewed, AI-assisted travel guides for destinations around the world.',
      slogan: SITE.tagline,
      foundingDate: '2026',
      // Named topical expertise + a transparent editorial policy are the E-E-A-T
      // signals AI search rewards. We deliberately attribute authorship to the
      // organization (a real editorial team), NOT a fabricated human byline.
      knowsAbout: [
        'Travel', 'Tourism', 'Travel destinations', 'Local food and restaurants',
        'Public transport', 'Visa requirements', 'Travel events and festivals',
      ],
      publishingPrinciples: `${siteUrl}/about`,
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#site`,
      name: siteName,
      url: siteUrl,
      description: SITE.description,
      publisher: { '@id': `${siteUrl}/#org` },
      inLanguage: 'en',
    },
  ],
};
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {/* Per-language webfont, loaded ONLY on that language's pages — the Latin
        faces have no CJK glyphs. Pretendard ships a dynamic subset (downloads
        just the glyphs used); Google serves Noto with unicode-range subsets.
        Spanish stays on Inter. Matching CSS lives in global.css. */}
    {lang === 'ko' && (
      <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
      />
    )}
    {(lang === 'ja' || lang === 'zh') && (
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    )}
    {lang === 'ja' && (
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap"
      />
    )}
    {lang === 'zh' && (
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;700&display=swap"
      />
    )}
    <title>{title.includes(siteName) ? title : (`${title} · ${siteName}`.length <= 60 ? `${title} · ${siteName}` : title)}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}
    {localized && <link rel="alternate" hreflang="x-default" href={new URL(localizePath(canonicalPath, 'en'), Astro.site).toString()} />}
    <!-- Allow large image previews (required for Google Discover cards) -->
    <meta name="robots" content={noindex ? 'noindex, follow, max-image-preview:large' : 'max-image-preview:large'} />
    <link rel="alternate" type="application/rss+xml" title={siteName} href="/rss.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteName} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter — explicit tags rather than relying on the OG fallback, so the
         large-image card renders reliably on X and in link unfurlers. -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <link rel="sitemap" href="/sitemap-index.xml" />

    <script type="application/ld+json" set:html={JSON.stringify(orgLd)} />

    <!-- Privacy-friendly analytics by Plausible (cookieless, no consent banner).
         Our `Affiliate click` custom events fire via window.plausible() below. -->
    <script is:inline async src="https://plausible.io/js/pa-8beY2XpeZiWKI7EzsoQ6f.js"></script>
    <script is:inline>
      window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
      plausible.init()
    </script>

    {
      jsonLd && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(jsonLd)}
        />
      )
    }

    <!-- Travelpayouts Drive — affiliate analytics + monetization (marker 553157).
         data-cfasync=false keeps Cloudflare Rocket Loader from deferring it. -->
    <script is:inline data-cfasync="false">
      (function () {
        var s = document.createElement('script');
        s.async = 1;
        s.src = 'https://emrld.ltd/NTUzMTU3.js?t=553157';
        document.head.appendChild(s);
      })();
    </script>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <script is:inline>
      // Outbound affiliate-click tracking. Fires to whatever analytics is present
      // (GA4/gtag, Plausible, or dataLayer) — a harmless no-op until one is added,
      // so we can measure which CTAs/widgets actually drive booking clicks.
      document.addEventListener('click', function (e) {
        var t = e.target;
        var a = t && t.closest && t.closest('a[rel~="sponsored"], a[href*="klook"], a[href*="hotellook"], a[href*="tp.media"], a[href*="tpx.lv"], a[href*="aviasales"]');
        if (!a) return;
        var label = (a.textContent || '').trim().slice(0, 60) || a.href;
        try {
          if (window.gtag) window.gtag('event', 'affiliate_click', { link_url: a.href, link_text: label });
          else if (window.plausible) window.plausible('Affiliate click', { props: { url: a.href } });
          (window.dataLayer = window.dataLayer || []).push({ event: 'affiliate_click', link_url: a.href, link_text: label });
        } catch (_) {}
      }, true);
    </script>
  </body>
</html>
