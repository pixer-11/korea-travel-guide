---
// "Plan your trip" affiliate block for every guide — booking services that are
// already active on our Travelpayouts account (marker 553157). Link-based
// programs use city-agnostic homepage links (readers pick their city there);
// flights point to our own /flights page. Affiliate links use rel="sponsored".
import { SITE } from '../siteConfig';
import Emoji from './Emoji.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { localizePlace } from '../i18n/places';
interface Props { city: string; country?: string }
const { city } = Astro.props;
// Labels follow the page's language; the `city` in affiliate links stays English
// (that's the search query the booking API expects), while the DISPLAYED city name
// is localized.
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const cityLabel = localizePlace(city, lang);

// City-specific Klook affiliate link, built automatically from the city name —
// works for every city (and every future auto-published post) with no per-city
// setup. Uses the account's own Klook redirect (campaign 13694, pid 754088);
// the query lands the reader on that city's tours & tickets.
const klookHref = city
  ? `https://affiliate.klook.com/redirect?aid=api%7C13694%7C-754088%7Cpid%7C754088&k_site=${encodeURIComponent(`https://www.klook.com/en-US/search/?query=${city}`)}`
  : 'https://klook.tpx.lv/2NXPH8MA';

const services = [
  { icon: 'admission-tickets', label: t('widget.toursLabel'), desc: city ? t('widget.toursDescCity').replace('{city}', cityLabel) : t('widget.toursDesc'), href: klookHref },
  { icon: 'automobile', label: t('widget.carLabel'), desc: t('widget.carDesc'), href: 'https://localrent.tpx.lv/qivp9ZCc' },
  { icon: 'taxi', label: t('widget.transferLabel'), desc: t('widget.transferDesc'), href: 'https://kiwitaxi.tpx.lv/yRbl5tlp' },
  { icon: 'antenna-bars', label: t('widget.esimLabel'), desc: t('widget.esimDesc'), href: 'https://yesim.tpx.lv/KABevuVe' },
  { icon: 'airplane', label: t('widget.flightsLabel'), desc: city ? t('widget.flightsDescCity').replace('{city}', cityLabel) : t('widget.flightsDesc'), href: '/flights', internal: true },
];
---
<section class="plan-trip">
  <div class="rule-head"><span class="kicker">{city ? t('widget.planTripCity').replace('{city}', cityLabel) : t('widget.planTrip')}</span></div>
  <div class="plan-grid">
    {services.map((s) => (
      <a
        class="plan-card"
        href={s.href}
        target={s.internal ? undefined : '_blank'}
        rel={s.internal ? undefined : 'sponsored noopener'}
      >
        <span class="plan-ico"><Emoji name={s.icon} /></span>
        <span class="plan-txt"><strong>{s.label}</strong><span>{s.desc}</span></span>
        <span class="plan-arw">→</span>
      </a>
    ))}
  </div>
  <p class="tp-disclosure">{t('widget.affDisclosure').replace('{site}', SITE.name)}</p>
</section>
