---
import Logo from './Logo.astro';
import { SITE } from '../siteConfig';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrap">
    <div>
      <a href="/" class="brand"><Logo size={24} /> <span>{SITE.name}</span></a>
      <p>
        Editor-reviewed, AI-assisted travel guides for destinations around the
        world. Facts sourced from live data; images are licensed or public domain.
      </p>
      <p style="margin-top:0.6rem">&copy; {year} {SITE.name}</p>
    </div>
    <nav>
      <a href="/destinations">Destinations</a>
      <a href="/about">Editorial policy</a>
      <a href="/contact">Contact</a>
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
    </nav>
  </div>
</footer>
