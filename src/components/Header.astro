---
import { getCollection } from 'astro:content';
import Logo from './Logo.astro';
import Flag from './Flag.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { SITE } from '../siteConfig';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import countriesData from '../../data/countries.json';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const posts = await getCollection('posts', ({ data }) => !data.draft);
const live = countriesData.countries.filter((c) =>
  posts.some((p) => (p.data.country ?? 'South Korea') === c.name)
);
const CONT_ORDER = ['Asia', 'Europe', 'North America', 'South America', 'Africa', 'Oceania', 'Other'];
const contSlug = (name) => name.toLowerCase().replace(/\s+/g, '-');
const navGroups = CONT_ORDER
  .map((k) => ({ name: k, slug: contSlug(k), countries: live.filter((c) => (c.continent || 'Other') === k) }))
  .filter((g) => g.countries.length);
---

<header class="site-header">
  <div class="wrap">
    <a href="/" class="brand"><Logo size={26} /> <span>{SITE.name}</span></a>

    <input type="checkbox" id="nav-toggle" hidden />
    <label for="nav-toggle" class="menu-toggle" aria-label="Menu">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </label>

    <nav class="nav">
      <div class="nav-dd">
        <a href="/destinations" class="nav-dd-toggle">{t('nav.destinations')} ▾</a>
        <div class="nav-dd-menu">
          {navGroups.map((g) => (
            <>
              <a class="nav-dd-head nav-dd-head-link" href={`/continents/${g.slug}`}>{g.name} →</a>
              {g.countries.map((c) => (
                <a href={`/destinations/${c.slug}`}><Flag code={c.iso2} class="flag-ico" /> {c.name}</a>
              ))}
            </>
          ))}
          <a href="/destinations" class="nav-dd-all">{t('nav.allDestinations')} →</a>
        </div>
      </div>
      <a href="/flights">{t('nav.flights')}</a>
      <a href="/about">{t('nav.about')}</a>
      <LanguageSwitcher />
    </nav>
  </div>
</header>
