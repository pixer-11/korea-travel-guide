---
import { getCollection } from 'astro:content';
import Logo from './Logo.astro';
import { SITE } from '../siteConfig';
import countriesData from '../../data/countries.json';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const liveCountries = countriesData.countries.filter((c) =>
  posts.some((p) => (p.data.country ?? 'South Korea') === c.name)
);
---

<header class="site-header">
  <div class="wrap">
    <a href="/" class="brand"><Logo size={26} /> <span>{SITE.name}</span></a>

    <input type="checkbox" id="nav-toggle" hidden />
    <label for="nav-toggle" class="menu-toggle" aria-label="Menu">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </label>

    <nav class="nav">
      <div class="nav-dd">
        <a href="/destinations" class="nav-dd-toggle">Destinations ▾</a>
        <div class="nav-dd-menu">
          {liveCountries.map((c) => (
            <a href={`/destinations/${c.slug}`}>{c.flag} {c.name}</a>
          ))}
          <a href="/destinations">All destinations →</a>
        </div>
      </div>
      <a href="/about">About</a>
    </nav>
  </div>
</header>
