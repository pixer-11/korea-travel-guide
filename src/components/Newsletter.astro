---
// Reusable newsletter signup — our own design, wired to MailerLite.
// Single email field + subscribe button (NO account). Submits directly to the
// MailerLite embedded-form endpoint (double opt-in is ON in MailerLite, so the
// real confirmation happens via an email we don't send ourselves). The endpoint
// returns {"success":true} with open CORS, so we read it for accurate feedback.
import { SITE } from '../siteConfig';
import { getLangFromUrl, useTranslations, type Lang } from '../i18n/utils';
import Icon from './Icon.astro';
interface Props { compact?: boolean; lang?: Lang }
const { compact = false, lang: langProp } = Astro.props;
const lang = langProp ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);
// Public embedded-form endpoint (account 2523042 · form 193609989933237794).
// Not a secret — it's the same URL in MailerLite's public embed code.
const ML_ACTION = 'https://assets.mailerlite.com/jsonp/2523042/forms/193609989933237794/subscribe';
---
<section id="newsletter" class:list={['newsletter', { 'newsletter-compact': compact }]}>
  <div class="wrap">
    <div class="nl-inner">
      <p class="kicker gold">{SITE.name} {t('home.newsletterKicker')}</p>
      <h2>{t('home.newsletterTitle')}</h2>
      <p class="nl-dek">{t('home.newsletterDek')}</p>
      <p class="nl-bonus"><Icon name="ph:gift" /> {t('home.newsletterBonus')}</p>
      <form class="nl-form" data-ml-action={ML_ACTION} novalidate>
        <input type="email" name="email" placeholder="you@email.com" aria-label="Email address" autocomplete="email" required />
        <button type="submit" class="btn btn-primary">{t('home.subscribe')}</button>
      </form>
      <p class="nl-note" hidden aria-live="polite"></p>
    </div>
  </div>
</section>

<script>
  // Wires every newsletter form on the page to MailerLite. Double opt-in means a
  // subscriber isn't active until they click the confirmation email — so on a
  // successful POST we tell them to check their inbox.
  document.querySelectorAll('.nl-form').forEach((el) => {
    const form = el as HTMLFormElement;
    const note = form.parentElement?.querySelector('.nl-note') as HTMLElement | null;
    const btn = form.querySelector('button[type=submit]') as HTMLButtonElement | null;
    const action = form.dataset.mlAction;
    const say = (msg: string, ok = false) => {
      if (!note) return;
      note.hidden = false;
      note.textContent = msg;
      note.classList.toggle('nl-note-ok', ok);
      note.classList.toggle('nl-note-err', !ok);
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = form.querySelector('input[name=email]') as HTMLInputElement | null;
      const email = input?.value?.trim() ?? '';
      if (!email || !/.+@.+\..+/.test(email)) { say('Please enter a valid email address.'); return; }
      if (!action) { say('Newsletter is launching soon — thanks for your interest!', true); return; }

      const data = new FormData();
      data.append('fields[email]', email);
      data.append('ml-submit', '1');
      data.append('anticsrf', 'true');

      const label = btn?.textContent ?? 'Subscribe';
      if (btn) { btn.disabled = true; btn.textContent = 'Subscribing…'; }
      try {
        // FormData keeps this a CORS-safelisted request (no preflight); the
        // endpoint allows any origin, so we can read the JSON result.
        const res = await fetch(action, { method: 'POST', body: data });
        const json = await res.json().catch(() => ({} as any));
        if (json && json.success) {
          form.reset();
          if (note) {
            note.hidden = false;
            note.classList.add('nl-note-ok');
            note.classList.remove('nl-note-err');
            note.innerHTML = 'Almost there! Check your inbox to confirm — then grab your free <a href="/free/trip-checklist">trip-planning checklist &rarr;</a>';
          }
        } else {
          say('Hmm, that didn’t go through. Please try again in a moment.');
        }
      } catch {
        say('Network hiccup — please try again in a moment.');
      } finally {
        if (btn) { btn.disabled = false; btn.textContent = label; }
      }
    });
  });
</script>
