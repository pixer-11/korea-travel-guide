---
// Reusable newsletter signup. Provider-agnostic UI — a single email field +
// subscribe button (NO account). Wire to the ESP (MailerLite) by replacing the
// form action / embed once it's set up; until then it shows an honest
// "launching soon" message and does NOT claim to store the address.
import { SITE } from '../siteConfig';
interface Props { compact?: boolean }
const { compact = false } = Astro.props;
---
<section class:list={['newsletter', { 'newsletter-compact': compact }]}>
  <div class="wrap">
    <div class="nl-inner">
      <p class="kicker gold">The {SITE.name} newsletter</p>
      <h2>{compact ? 'Get one useful travel guide a week.' : 'One genuinely useful travel guide, every week.'}</h2>
      <p class="nl-dek">New destinations, insider itineraries, and the practical stuff that saves your trip. No spam — unsubscribe anytime.</p>
      <form class="nl-form" novalidate>
        <input type="email" name="email" placeholder="you@email.com" aria-label="Email address" required />
        <button type="submit" class="btn btn-primary">Subscribe</button>
      </form>
      <p class="nl-note" hidden></p>
    </div>
  </div>
</section>

<script>
  // Handles every newsletter form on the page. NOT connected to a provider yet,
  // so it intentionally does NOT claim to have stored the email (Phase 2 wires
  // this to MailerLite).
  document.querySelectorAll('.nl-form').forEach((form) => {
    const note = form.parentElement?.querySelector('.nl-note') as HTMLElement | null;
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const input = form.querySelector('input[name=email]') as HTMLInputElement | null;
      const email = input?.value?.trim() ?? '';
      if (!email || !/.+@.+\..+/.test(email)) {
        if (note) { note.hidden = false; note.textContent = 'Please enter a valid email.'; }
        return;
      }
      (form as HTMLFormElement).reset();
      if (note) { note.hidden = false; note.textContent = 'Our newsletter is launching soon — subscriptions open shortly. Thanks for your interest!'; }
    });
  });
</script>
