---
// "Top-rated things to do in {city}" — for the 16 mapped cities we render the
// Klook price widget (tpemd.com, numeric city_id). For EVERY other city we now
// render a Klook city-search CTA instead of nothing, so tours (our best-
// converting, no-approval-needed inventory) monetize on every post.
// marker shmarker=754088, source trs=553157, category 1 = Attractions & Shows.
import Emoji from './Emoji.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { localizePlace } from '../i18n/places';
interface Props { city: string }
const { city } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const cityLabel = localizePlace(city, lang);

// Travelpayouts Klook city_id map (from the widget's city dropdown) — expand as
// more ids are confirmed. Keys must match a post's `region` value exactly.
const CITY_ID: Record<string, number> = {
  Seoul: 13,
  Busan: 46,
  Incheon: 158,
  Tokyo: 28,
  Osaka: 29,
  Kyoto: 30,
  Fukuoka: 23442,
  Sapporo: 133938,
  Okinawa: 6484,
  Nagoya: 71,
  Nara: 7062,
  Hiroshima: 5122,
  Bangkok: 4,
  Phuket: 7,
  Shanghai: 59,
  Xian: 60,
};
const cityId = CITY_ID[city];
const src = cityId
  ? `https://tpemd.com/content?currency=USD&trs=553157&shmarker=754088&locale=en&city_id=${cityId}&category=1&amount=3&powered_by=true&campaign_id=137&promo_id=4497`
  : null;

// Fallback for unmapped cities: a city-specific Klook search link (works for any
// city, correct attribution via the account's own Klook redirect).
const klookHref = city
  ? `https://affiliate.klook.com/redirect?aid=api%7C13694%7C-754088%7Cpid%7C754088&k_site=${encodeURIComponent(`https://www.klook.com/en-US/search/?query=${city}`)}`
  : 'https://klook.tpx.lv/2NXPH8MA';
---
{city && (
  <section class="tp-tours">
    <div class="rule-head"><span class="kicker">{t('widget.topThingsToDo').replace('{city}', cityLabel)}</span></div>
    {src ? (
      <div class="tp-widget-card">
        <script is:inline async src={src} charset="utf-8"></script>
      </div>
    ) : (
      <a class="plan-card tours-cta" href={klookHref} target="_blank" rel="sponsored noopener">
        <span class="plan-ico"><Emoji name="admission-tickets" /></span>
        <span class="plan-txt"><strong>{t('widget.toursInCity').replace('{city}', cityLabel)}</strong><span>{t('widget.toursCtaDesc')}</span></span>
        <span class="plan-arw">→</span>
      </a>
    )}
    <p class="tp-disclosure">{t('widget.livePrices')}</p>
  </section>
)}

<script>
  // Safety net: hide the block ONLY when the price widget rendered empty. The
  // link-fallback (no .tp-widget-card) always stays.
  window.addEventListener('load', () => {
    setTimeout(() => {
      document.querySelectorAll('.tp-tours').forEach((sec) => {
        const card = sec.querySelector('.tp-widget-card') as HTMLElement | null;
        if (card && !(card.querySelector('iframe') || card.offsetHeight > 120)) {
          (sec as HTMLElement).style.display = 'none';
        }
      });
    }, 3500);
  });
</script>
