---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from './PostCard.astro';
import Flag from './Flag.astro';
import Emoji from './Emoji.astro';
import Newsletter from './Newsletter.astro';
import Search from './Search.astro';
import { SITE } from '../siteConfig';
import { useTranslations, localizePath, type Lang } from '../i18n/utils';
import { localizePlace } from '../i18n/places';
import { loadCardTranslations, cardHelpers } from '../i18n/cards';
import { pickRepHeroUrl } from '../lib/repImage';
import countriesData from '../../data/countries.json';
import wallData from '../../data/wall.json';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
// Localized card titles/descriptions (from postI18n) so the homepage shows
// translated post titles, not the English source — matches the region/country hubs.
const tr = await loadCardTranslations(lang);
const card = cardHelpers(tr, lang);

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const flagship = ['jeju-seongsan-ilchulbong', 'seoul-gyeongbokgung-palace', 'sokcho-seoraksan-cable-car', 'busan-haeundae'];
const cover = flagship.map((s) => posts.find((p) => p.id === s)).find(Boolean) ?? posts[0];
const rest = posts.filter((p) => p.id !== cover?.id);
const latest = rest.slice(0, 3);
// Don't showcase weak auto-generated cards on the highest-authority page. Food/
// trendy venues still on a city/landmark fallback hero undercut the "real places,
// real photos" promise; attractions/events read fine with a landmark shot, but
// food venues must have their OWN self-hosted photo (/venue-photos/) to appear here.
const trustworthyCard = (p) => {
  const cat = p.data.category;
  if (cat === 'attraction' || cat === 'event' || cat === 'essentials') return true;
  return (p.data.heroImage?.url || '').includes('/venue-photos/');
};
const latestIds = new Set(latest.map((p) => p.id));
const moreGuides = rest.filter((p) => !latestIds.has(p.id) && trustworthyCard(p)).slice(0, 6);

const seed = Number(new Date().toISOString().slice(0, 10).replace(/-/g, '')) || 1;
function shuffle(arr) {
  const a = [...arr];
  let s = seed;
  for (let i = a.length - 1; i > 0; i--) {
    s = (s * 9301 + 49297) % 233280;
    const j = Math.floor((s / 233280) * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}
// data/wall.json already stores the pre-generated 640px WebP thumbnail PATHS
// (scripts/build-wall.mjs) — e.g. "/wall/<hash>.webp" — so use them directly.
const wall = shuffle(wallData.images ?? []).slice(0, 12).map((url) => ({ url }));
const wallRow1 = wall.slice(0, 6);
const wallRow2 = wall.slice(6, 12);

const countFor = (name) => posts.filter((p) => (p.data.country ?? 'South Korea') === name).length;
const countries = countriesData.countries.map((c) => ({ ...c, count: countFor(c.name) }));
const live = countries.filter((c) => c.count > 0);
const soon = countries.filter((c) => c.count === 0);
const repImage = (name) => pickRepHeroUrl(posts.filter((p) => (p.data.country ?? 'South Korea') === name));

const koreaLinks = [
  { label: 'Seoul', href: '/regions/seoul' },
  { label: 'Busan', href: '/regions/busan' },
  { label: 'Jeju', href: '/regions/jeju' },
  { label: 'Gyeongju', href: '/regions/gyeongju' },
];
---

<BaseLayout
  title={`${SITE.name} — ${t('home.tagline')}`}
  description={t('home.heroDek')}
  image={cover?.data.heroImage?.url}
  localized={true}
>
  <section class="hero-wall">
    <div class="wall-rows" aria-hidden="true">
      <div class="wall-row r1">
        {[...wallRow1, ...wallRow1].map((im) => <img src={im.url} alt="" width="640" height="427" decoding="async" />)}
      </div>
      <div class="wall-row r2">
        {[...wallRow2, ...wallRow2].map((im) => <img src={im.url} alt="" width="640" height="427" loading="lazy" decoding="async" />)}
      </div>
    </div>
    <div class="cover-scrim"></div>
    <div class="cover-inner wrap">
      <p class="kicker gold">{t('home.tagline')}</p>
      <h1>{t('home.heroTitle')}</h1>
      <p class="cover-dek">{t('home.heroDek')}</p>
      <Search placeholder={t('home.searchPlaceholder')} />
      <div class="cover-cta-row">
        <a class="cover-cta" href={localizePath('/destinations', lang)}>{t('home.exploreDestinations')} <span class="arw">→</span></a>
        {cover && <a class="cover-cta cover-cta-soft" href={localizePath(`/posts/${cover.id}`, lang)}>{t('home.featured')}: {localizePlace(cover.data.region, lang)} <span class="arw">→</span></a>}
      </div>
      <p class="cover-scale">{t('home.trustBar').replace('{n}', String(live.length))}</p>
    </div>
  </section>

  {latest.length > 0 && (
    <section class="section">
      <div class="wrap">
        <div class="rule-head"><span class="kicker">{t('home.latestStories')}</span></div>
        <div class="stories">
          {latest.map((post) => (
            <a class="story" href={localizePath(`/posts/${post.id}`, lang)}>
              <div class="story-thumb">
                <img src={post.data.heroImage?.url ?? '/images/placeholder-market.svg'} alt={post.data.place?.name ?? post.data.title} loading="lazy" width="600" height="400" />
              </div>
              <span class="kicker gold">{t(`cat.${post.data.category}` as any)}</span>
              <h3>{card.title(post.id, post.data.title)}</h3>
              <p class="story-meta">{localizePlace(post.data.region, lang)} · {localizePlace(post.data.country ?? 'South Korea', lang)}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section">
    <div class="wrap">
      <div class="spotlight">
        <div class="spotlight-media">
          <img src={cover?.data.heroImage?.url ?? '/images/placeholder-market.svg'} alt="South Korea" loading="lazy" width="800" height="1000" />
        </div>
        <div class="spotlight-body">
          <p class="kicker gold"><Flag code="kr" class="flag-ico" /> {t('home.destinations')}</p>
          <h2>{localizePlace('South Korea', lang)}</h2>
          <p>{t('home.spotlightDesc').replace('{n}', String(countFor('South Korea')))}</p>
          <div class="spotlight-links">
            {koreaLinks.map((l) => <a href={localizePath(l.href, lang)}>{localizePlace(l.label, lang)}</a>)}
          </div>
          <a class="btn btn-primary" href={localizePath('/destinations/south-korea', lang)}>{localizePlace('South Korea', lang)} →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="rule-head">
        <span class="kicker">{t('home.destinations')}</span>
        <a href={localizePath('/destinations', lang)} class="rule-link">{t('nav.allDestinations')} →</a>
      </div>
      <p class="bento-note">{t('home.bentoNote').replace('{n}', String(live.length))}</p>
      <div class="dest-bento">
        {live.map((c, i) => (
          <a class:list={['dest-tile', 'dest-live', { 'dest-feat': i === 0 }]} href={localizePath(`/destinations/${c.slug}`, lang)} style={`background-image:url(${repImage(c.name)})`}>
            {i === 0 && <span class="dest-ribbon">{t('home.featured')}</span>}
            <div class="dest-tile-inner">
              <span class="dest-flag"><Flag code={c.iso2} /></span>
              <h3>{localizePlace(c.name, lang)}</h3>
              <p>{t('home.guides').replace('{n}', String(c.count))} →</p>
            </div>
          </a>
        ))}
        {soon.map((c) => (
          <div class="dest-tile dest-soon">
            <div class="dest-tile-inner">
              <span class="dest-flag"><Flag code={c.iso2} /></span>
              <h3>{localizePlace(c.name, lang)}</h3>
              <p class="dest-pill">{t('home.comingSoon')}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="wrap">
      <div class="rule-head"><span class="kicker">{t('home.travelEssentials')}</span></div>
      <div class="essentials-strip">
        <a class="essential-card" href={localizePath('/essentials/visa', lang)}><span class="ico"><Emoji name="passport-control" /></span><div><h3>{t('ess.visa')}</h3><p>{t('ess.visaDek')}</p></div></a>
        <a class="essential-card" href={localizePath('/essentials/transport', lang)}><span class="ico"><Emoji name="metro" /></span><div><h3>{t('ess.transport')}</h3><p>{t('ess.transportDek')}</p></div></a>
        <a class="essential-card" href={localizePath('/essentials/money', lang)}><span class="ico"><Emoji name="credit-card" /></span><div><h3>{t('ess.money')}</h3><p>{t('ess.moneyDek')}</p></div></a>
        <a class="essential-card" href={localizePath('/essentials/best-time-to-visit', lang)}><span class="ico"><Emoji name="cherry-blossom" /></span><div><h3>{t('ess.bestTime')}</h3><p>{t('ess.bestTimeDek')}</p></div></a>
        <a class="essential-card" href={localizePath('/essentials/emergency', lang)}><span class="ico"><Emoji name="police-car-light" /></span><div><h3>{t('ess.emergency')}</h3><p>{t('ess.emergencyDek')}</p></div></a>
      </div>
      <p style="margin-top:1.25rem"><a href={localizePath('/essentials', lang)} class="rule-link">{t('ess.all')} →</a></p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="trust">
        <div><h3>{t('trust.reviewedTitle')}</h3><p>{t('trust.reviewedText')}</p></div>
        <div><h3>{t('trust.factsTitle')}</h3><p>{t('trust.factsText')}</p></div>
        <div><h3>{t('trust.updatedTitle')}</h3><p>{t('trust.updatedText')}</p></div>
      </div>
    </div>
  </section>

  <Newsletter lang={lang} />

  {moreGuides.length > 0 && (
    <section class="section">
      <div class="wrap">
        <div class="rule-head"><span class="kicker">{t('home.moreToRead')}</span></div>
        <div class="grid">
          {moreGuides.map((post) => (
            <PostCard
              href={localizePath(`/posts/${post.id}`, lang)}
              title={card.title(post.id, post.data.title)}
              description={card.desc(post.id, post.data.description)}
              region={post.data.region}
              category={post.data.category}
              image={post.data.heroImage?.url}
                  eventEndDate={post.data.eventEndDate}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <script>
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!reduce && 'IntersectionObserver' in window) {
      const els = Array.from(document.querySelectorAll('main .story, main .dest-tile, main .essential-card, main .card')) as HTMLElement[];
      els.forEach((el) => el.classList.add('js-reveal'));
      const io = new IntersectionObserver((entries, obs) => {
        entries.forEach((e) => { if (e.isIntersecting) { (e.target as HTMLElement).classList.add('in'); obs.unobserve(e.target); } });
      }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });
      els.forEach((el) => io.observe(el));
      setTimeout(() => els.forEach((el) => el.classList.add('in')), 1500);
    }
  </script>
</BaseLayout>
