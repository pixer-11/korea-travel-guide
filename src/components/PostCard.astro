---
import { isEventPast } from '../lib/eventStatus';
import { getLangFromUrl } from '../i18n/utils';
import { localizePlace } from '../i18n/places';
interface Props {
  href: string;
  title: string;
  description: string;
  region: string;
  category: string;
  image?: string;
  eventEndDate?: Date | string | null;
}
const { href, title, description, region, category, image, eventEndDate } = Astro.props;
// Card labels follow the page's language (cards appear on localized hubs too).
const regionLabel = localizePlace(region, getLangFromUrl(Astro.url));
const label = category.replace('-', ' ');
const ended = isEventPast({ category, eventEndDate });
---

<a class:list={['card', { 'card--ended': ended }]} href={href}>
  <div class="thumb">
    <img src={image ?? '/images/placeholder-market.svg'} alt={`${title} — ${region}`} width="600" height="400" loading="lazy" decoding="async" />
    {ended ? <span class="badge badge-ended">이벤트 종료 · Ended</span> : <span class="badge">{label}</span>}
  </div>
  <div class="card-body">
    <span class="region-label">{regionLabel}</span>
    <h3>{title}</h3>
    <p>{description}</p>
  </div>
</a>
