---
// Wander Atlas mark — a compass rose inside a globe ring. Uses currentColor so
// the header/footer can tint it; scales cleanly to favicon size.
interface Props { size?: number; }
const { size = 28 } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 32 32" fill="none" class="logo-mark" aria-hidden="true">
  <circle cx="16" cy="16" r="13" stroke="currentColor" stroke-width="1.5" opacity="0.4" />
  <path
    d="M16 4.5 L18.4 13.6 L27.5 16 L18.4 18.4 L16 27.5 L13.6 18.4 L4.5 16 L13.6 13.6 Z"
    fill="currentColor"
  />
</svg>
