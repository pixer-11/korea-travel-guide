---
// Per-post "Where to stay" block. This Travelpayouts account has no dedicated
// hotel-search widget, and Hotels.com/Booking are locked until the site has 3
// months of stable traffic. So hotels are monetized through KLOOK — an ACTIVE
// program on the account (already tracking clicks) whose "Hotels & Accommodations"
// category pays 2-5%. Klook is Asia-strong, which fits our Asia-heavy content.
// The link is a per-city Klook hotel search via the account's Klook affiliate
// redirect (pid 754088 → preserves attribution). UPGRADE PLAN: switch to
// Hotels.com once traffic unlocks it (~3 months) for better hotel-specific rates.
import Emoji from './Emoji.astro';
interface Props { city: string; country?: string }
const { city, country } = Astro.props;
const klookSearch = `https://www.klook.com/en-US/search/?query=${city} hotels`;
const href = `https://affiliate.klook.com/redirect?aid=api%7C13694%7C-754088%7Cpid%7C754088&k_site=${encodeURIComponent(klookSearch)}`;
---
<section class="tp-hotels">
  <div class="rule-head"><span class="kicker">Where to stay in {city}</span></div>
  <div class="hotels-cta">
    <p>Compare hotels and stays in {city} — deals, ratings, and real traveler reviews.</p>
    <a class="btn btn-primary" href={href} target="_blank" rel="sponsored noopener"><Emoji name="hotel" /> Search hotels in {city} &rarr;</a>
  </div>
  <p class="tp-disclosure">Booking links are affiliate links — booking through them supports our free guides at no extra cost to you.</p>
</section>

<style>
  .hotels-cta {
    background: var(--surface-2);
    border: 1px solid var(--line);
    border-radius: var(--r-md);
    padding: 1.3rem 1.4rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.9rem;
  }
  .hotels-cta p { margin: 0; color: var(--muted); max-width: 46ch; }
</style>
