---
// Per-post "Where to stay" block. This Travelpayouts account has NO Hotellook
// hotel-search WIDGET available (Tools → Widgets lists no hotel brand), so rather
// than embed an empty widget that just auto-hides, we show a reliable, always-
// visible hotel-search CTA. It's a marker-tracked Hotellook search link (marker
// 754088) — the same working link the top-of-post "Find hotels" button uses — so
// it needs no widget/campaign approval and tracks under our account. If a hotel
// search widget ever becomes available, swap this for the inline-price widget.
interface Props { city: string; country?: string }
const { city, country } = Astro.props;
const dest = [city, country].filter(Boolean).join(', ');
const href = `https://search.hotellook.com/?marker=754088&destination=${encodeURIComponent(dest)}`;
---
<section class="tp-hotels">
  <div class="rule-head"><span class="kicker">Where to stay in {city}</span></div>
  <div class="hotels-cta">
    <p>Compare live nightly prices for {city} across hundreds of booking sites — shown in your local currency.</p>
    <a class="btn btn-primary" href={href} target="_blank" rel="sponsored noopener">🏨 Search hotels in {city} &rarr;</a>
  </div>
  <p class="tp-disclosure">Booking links are affiliate links — booking through them supports our free guides at no extra cost to you.</p>
</section>

<style>
  .hotels-cta {
    background: var(--surface-2);
    border: 1px solid var(--line);
    border-radius: var(--r-md);
    padding: 1.3rem 1.4rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.9rem;
  }
  .hotels-cta p { margin: 0; color: var(--muted); max-width: 46ch; }
</style>
